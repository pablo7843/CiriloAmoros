---
import { site } from "../data/site";

const steps = [
  {
    n:     "01",
    title: "Contáctenos",
    desc:  "Escríbanos, llámenos o use el formulario. Le respondemos el mismo día laborable y resolvemos sus dudas sin ningún compromiso.",
  },
  {
    n:     "02",
    title: "Venga a conocernos",
    desc:  "Visitamos juntos los espacios disponibles. Le enseñamos las instalaciones y le explicamos en detalle todo lo que incluye cada modalidad.",
  },
  {
    n:     "03",
    title: "Empiece a trabajar",
    desc:  "Firmamos el contrato y tiene su despacho listo desde el primer día. Acceso 24/7, internet, recepción. Sin inversión inicial, sin sorpresas.",
  },
];
---

<section aria-labelledby="como-funciona-titulo" class="overflow-hidden bg-gray-950 py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-6">

    <!-- Cabecera -->
    <div class="mb-16 max-w-2xl" data-reveal>
      <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-400">Cómo funciona</p>
      <h2
        id="como-funciona-titulo"
        class="text-4xl font-bold leading-[1.08] tracking-tight text-white sm:text-5xl"
      >
        De interesado<br />a instalado en días.
      </h2>
    </div>

    <!-- Pasos -->
    <div class="relative grid grid-cols-1 gap-12 sm:gap-10 lg:grid-cols-3">

      <!-- Línea de conexión animada, solo desktop -->
      <div
        class="line-draw absolute left-0 right-0 top-[1.9rem] hidden h-px bg-gradient-to-r from-transparent via-gray-700 to-transparent lg:block"
        aria-hidden="true"
        data-reveal
      ></div>

      {steps.map((step, i) => (
        <div class="relative flex flex-col gap-6" data-reveal style={`transition-delay: ${i * 120}ms`}>
          <!-- Círculo numerado -->
          <div class="inline-flex h-[3.75rem] w-[3.75rem] shrink-0 items-center justify-center rounded-full border border-gray-700 bg-gray-900">
            <span class="text-base font-bold tabular-nums text-white">{step.n}</span>
          </div>

          <!-- Texto -->
          <div>
            <h3 class="mb-2 text-xl font-semibold text-white">{step.title}</h3>
            <p class="text-[15px] leading-relaxed text-gray-400">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTAs -->
    <div class="mt-16 flex flex-wrap gap-4" data-reveal style="transition-delay: 360ms">
      <a
        href="/contacto?motivo=visita"
        class="inline-flex items-center rounded-xl bg-white px-6 py-3.5 text-sm font-semibold text-gray-900
               shadow-sm transition-colors hover:bg-gray-100
               focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-950"
      >
        Solicitar visita sin compromiso
      </a>
      <a
        href={site.contact.phoneHref}
        class="inline-flex items-center gap-2 rounded-xl border border-gray-700 px-6 py-3.5 text-sm font-medium
               text-gray-300 transition-colors hover:border-gray-500 hover:text-white
               focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-950"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
        </svg>
        {site.contact.phone}
      </a>
    </div>
  </div>
</section>
