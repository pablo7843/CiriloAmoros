---
/**
 * Mascota robot original (no es ningún personaje con marca registrada).
 * Saluda con la mano y flota suave. Azul de acento del sitio.
 * Se congela bajo prefers-reduced-motion (regla global de animaciones).
 */
interface Props { class?: string }
const { class: cls = "h-24 w-auto" } = Astro.props;
---

<svg class={`robot ${cls}`} viewBox="0 0 120 140" fill="none" role="img" aria-label="Asistente con IA" xmlns="http://www.w3.org/2000/svg">
  <!-- Sombra -->
  <ellipse cx="60" cy="134" rx="26" ry="4" fill="#0f172a" opacity="0.08"/>

  <!-- Antena -->
  <line x1="60" y1="16" x2="60" y2="30" stroke="#5266eb" stroke-width="3" stroke-linecap="round"/>
  <circle cx="60" cy="12" r="5" fill="#5266eb"/>

  <!-- Brazo derecho -->
  <rect x="87" y="88" width="9" height="22" rx="4.5" fill="#5266eb"/>

  <!-- Cuerpo -->
  <rect x="40" y="84" width="40" height="34" rx="14" fill="#ffffff" stroke="#5266eb" stroke-width="2.5"/>
  <circle cx="60" cy="101" r="4.5" fill="none" stroke="#5266eb" stroke-width="2"/>

  <!-- Piernas -->
  <rect x="48" y="116" width="9" height="13" rx="4.5" fill="#5266eb"/>
  <rect x="63" y="116" width="9" height="13" rx="4.5" fill="#5266eb"/>

  <!-- Cabeza -->
  <rect x="28" y="28" width="64" height="52" rx="18" fill="#ffffff" stroke="#5266eb" stroke-width="2.5"/>
  <!-- Visor -->
  <rect x="37" y="40" width="46" height="24" rx="12" fill="#5266eb"/>
  <!-- Ojos -->
  <circle cx="51" cy="52" r="4.2" fill="#ffffff"/>
  <circle cx="69" cy="52" r="4.2" fill="#ffffff"/>
  <circle cx="52.5" cy="50.5" r="1.4" fill="#5266eb"/>
  <circle cx="70.5" cy="50.5" r="1.4" fill="#5266eb"/>
  <!-- Sonrisa -->
  <path d="M53 71 Q60 76 67 71" stroke="#5266eb" stroke-width="2.4" stroke-linecap="round" fill="none"/>

  <!-- Brazo izquierdo que saluda (dibujado al final → pasa por DELANTE de la cabeza) -->
  <g class="robot-arm">
    <rect x="25" y="72" width="9" height="24" rx="4.5" fill="#5266eb"/>
    <circle cx="29.5" cy="70" r="6" fill="#5266eb"/>
  </g>
</svg>

<style>
  .robot { animation: robotBob 3s ease-in-out infinite; transform-origin: 50% 100%; }
  @keyframes robotBob {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-5px); }
  }
  .robot-arm {
    transform-box: fill-box;
    transform-origin: 50% 95%;
    animation: robotWave 1.1s ease-in-out infinite;
  }
  @keyframes robotWave {
    0%, 100% { transform: rotate(10deg); }
    50%      { transform: rotate(-24deg); }
  }
</style>
