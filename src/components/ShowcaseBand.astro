---
/**
 * Banda visual reutilizable — foto ancha a sangre con velo y titular encima.
 * Da aire y peso visual a las páginas internas (que si no son solo texto).
 * La imagen usa data-parallax-img → parallax sutil con el motor de BaseLayout.
 * Fotos = stock provisional (sustituir por reales).
 */
interface Props {
  image:    string;
  eyebrow?: string;
  title:    string;
  text?:    string;
  chips?:   string[];
}
const { image, eyebrow, title, text, chips = [] } = Astro.props;
---

<section class="bg-white py-10 sm:py-16">
  <div class="mx-auto max-w-7xl px-6">
    <div
      class="relative overflow-hidden rounded-3xl bg-gray-900 shadow-lg"
      data-reveal
    >
      <!-- Foto -->
      <div class="relative min-h-[440px] sm:min-h-[440px]">
        <img
          src={image}
          alt=""
          data-parallax-img
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
        <!-- Velo para legibilidad -->
        <div class="absolute inset-0 bg-gradient-to-t from-gray-950/85 via-gray-950/40 to-gray-950/10"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-gray-950/60 to-transparent"></div>
      </div>

      <!-- Contenido -->
      <div class="absolute inset-0 flex flex-col justify-end p-7 sm:p-12">
        <div class="max-w-2xl">
          {eyebrow && (
            <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-300">{eyebrow}</p>
          )}
          <h2 class="headline text-2xl leading-[1.12] text-white sm:text-4xl">{title}</h2>
          {text && (
            <p class="mt-4 max-w-xl text-sm leading-relaxed text-gray-300 sm:text-base">{text}</p>
          )}
          {chips.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2.5">
              {chips.map((c) => (
                <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3.5 py-1.5 text-xs font-medium text-white backdrop-blur-sm">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent-400"></span>
                  {c}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
