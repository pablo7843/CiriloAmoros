---
import { site } from "../data/site";
import Stars from "./Stars.astro";

const rating     = site.google.rating.toFixed(1).replace(".", ",");
const yearsOpen  = new Date().getFullYear() - site.founded;
---

<section aria-label="Por qué elegirnos" class="border-y border-gray-100 bg-gray-50">
  <div
    class="mx-auto flex max-w-7xl flex-wrap items-center justify-center
           gap-x-8 gap-y-4 px-6 py-5 sm:gap-x-10"
  >

    <!-- Google rating ──────────────────────────────────── -->
    <a
      href={site.google.businessUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center gap-2.5 text-sm"
      aria-label={`${rating} estrellas en Google — ver el perfil`}
    >
      <Stars rating={site.google.rating} class="h-4 w-4" />
      <span class="text-gray-700">
        <strong class="font-semibold">{rating}</strong>
        {" "}en Google
      </span>
      <svg
        class="h-3.5 w-3.5 text-gray-300 transition-colors group-hover:text-gray-500"
        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
      </svg>
    </a>

    <span class="hidden h-5 w-px bg-gray-200 sm:block" aria-hidden="true"></span>

    <!-- Acceso 24/7 ────────────────────────────────────── -->
    <div class="flex items-center gap-2 text-sm text-gray-600">
      <svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" viewBox="0 0 24 24"
        stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      Acceso <strong class="ml-1 font-semibold text-gray-800">24/7</strong>
    </div>

    <span class="hidden h-5 w-px bg-gray-200 lg:block" aria-hidden="true"></span>

    <!-- Años de actividad ──────────────────────────────── -->
    <div class="flex items-center gap-2 text-sm text-gray-600">
      <svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" viewBox="0 0 24 24"
        stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
      </svg>
      Centro de negocios
      <strong class="ml-1 font-semibold text-gray-800">desde {site.founded}</strong>
    </div>

    <span class="hidden h-5 w-px bg-gray-200 lg:block" aria-hidden="true"></span>

    <!-- Todo incluido ──────────────────────────────────── -->
    <div class="flex items-center gap-2 text-sm text-gray-600">
      <svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" viewBox="0 0 24 24"
        stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      Todo incluido ·
      <strong class="ml-1 font-semibold text-gray-800">desde 320 €/mes</strong>
    </div>

  </div>
</section>
