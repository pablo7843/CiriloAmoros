---
/**
 * Antes era la lista de preguntas frecuentes. Ahora las dudas se resuelven
 * con el chatbot de IA, así que esta sección es una llamada a abrir el chat
 * (con la mascota saludando). Se mantiene el nombre/props para no tocar las
 * páginas que ya la usan. El conocimiento de las FAQ sigue en src/data/faq.ts
 * porque alimenta al chatbot.
 */
import Robot from "./Robot.astro";

interface Props {
  category?: string;
  limit?: number;
}
---

<section aria-labelledby="ia-cta-titulo" class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-4xl px-6" data-reveal>
    <div class="relative rounded-3xl bg-gradient-to-br from-accent-50 to-white px-7 py-10 ring-1 ring-accent-100 sm:px-12 sm:py-12">
      <div class="pointer-events-none absolute -top-10 left-6 sm:left-10">
        <Robot class="h-24 w-auto" />
      </div>
      <div class="pt-14 sm:pt-6">
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">
          Asistente con IA
        </p>
        <h2 id="ia-cta-titulo" data-split class="headline text-3xl text-gray-900 sm:text-4xl">
          ¿Tienes dudas? Pregúntale a nuestra IA.
        </h2>
        <p class="mt-3 max-w-xl text-base leading-relaxed text-gray-500">
          Te responde al instante sobre despachos, precios, ubicación, horario o acceso 24h.
          Y si lo prefieres, te pone en contacto con el equipo.
        </p>
        <button
          type="button"
          onclick="window.dispatchEvent(new CustomEvent('cirilo:open-chat'))"
          class="btn-primary mt-7"
        >
          Abrir el chat
        </button>
      </div>
    </div>
  </div>
</section>
