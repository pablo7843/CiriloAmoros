---
/**
 * Portada de entrada — "primer folio".
 * Foto real del espacio a sangre con parallax (puntero + scroll) y el
 * monograma dibujándose encima. La web sube y la va cubriendo al hacer scroll
 * (lógica en BaseLayout). Estática y legible bajo prefers-reduced-motion.
 *
 * [PLACEHOLDER] La foto /images/intro-bg.webp es una imagen de stock provisional.
 * Sustituir por una foto REAL del centro cuando Alba pase el reportaje.
 */
---

<div
  id="intro"
  class="fixed inset-0 -z-[1] overflow-hidden bg-gray-950"
  aria-hidden="true"
>
  <!-- Capa de foto (parallax) -->
  <img
    id="intro-photo"
    src="/images/intro-bg.webp"
    alt=""
    class="absolute inset-0 h-full w-full scale-[1.14] object-cover will-change-transform"
    fetchpriority="high"
    decoding="async"
  />

  <!-- Velos para legibilidad del logo blanco -->
  <div class="intro-scrim absolute inset-0"></div>
  <div class="intro-vignette absolute inset-0"></div>

  <!-- Partículas sutiles de luz -->
  <span class="particle" style="left: 16%; animation-delay: 0s"></span>
  <span class="particle" style="left: 34%; animation-delay: 3.1s"></span>
  <span class="particle" style="left: 52%; animation-delay: 1.4s"></span>
  <span class="particle" style="left: 70%; animation-delay: 4.2s"></span>
  <span class="particle" style="left: 86%; animation-delay: 2.2s"></span>

  <!-- Contenido central -->
  <div class="intro-stage absolute inset-0 flex flex-col items-center justify-center px-6 text-center">
    <!-- Logo que se dibuja -->
    <svg class="intro-logo" viewBox="0 0 52 52" fill="none">
      <path class="intro-stroke s1" d="M17 5 L5 5 L5 47 L17 47" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path class="intro-stroke s2" d="M35 5 L47 5 L47 47 L35 47" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
      <line class="intro-stroke s3" x1="26" y1="10" x2="26" y2="42" stroke-width="3.5" stroke-linecap="round"/>
    </svg>

    <!-- Kicker con contexto -->
    <p class="intro-kicker">Centro Empresarial · Valencia</p>
    <h2 class="intro-title">Tu oficina en el corazón de Valencia</h2>

    <!-- Pista de scroll -->
    <div class="intro-hint" aria-hidden="true">
      <span class="intro-hint-text">Desliza para entrar</span>
      <svg class="intro-hint-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"/>
      </svg>
    </div>
  </div>
</div>

<style>
  /* Velo en degradado: oscurece arriba/abajo y un poco el centro para que
     el logo blanco y el texto siempre tengan contraste sobre la foto. */
  .intro-scrim {
    background:
      radial-gradient(120% 90% at 50% 46%, rgba(8, 12, 24, 0.30) 0%, rgba(8, 12, 24, 0.62) 100%),
      linear-gradient(to bottom, rgba(8, 12, 24, 0.55) 0%, rgba(8, 12, 24, 0.25) 30%, rgba(8, 12, 24, 0.45) 70%, rgba(8, 12, 24, 0.80) 100%);
  }
  /* Tinte de acento muy leve + viñeta */
  .intro-vignette {
    background: radial-gradient(70% 60% at 50% 48%, rgba(82, 102, 235, 0.16), transparent 70%);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  /* ── Logo ── */
  .intro-logo {
    width: min(300px, 50vmin);
    height: auto;
    animation: logoGlow 4s ease-in-out infinite;
  }
  @keyframes logoGlow {
    0%, 100% { filter: drop-shadow(0 0 18px rgba(120, 140, 255, 0.45)); }
    50%      { filter: drop-shadow(0 0 38px rgba(120, 140, 255, 0.70)); }
  }
  .intro-stroke {
    stroke: #ffffff;
    fill: none;
    stroke-dasharray: 84;
    stroke-dashoffset: 84;
    animation: draw 1.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .intro-stroke.s2 { animation-delay: 0.28s; }
  .intro-stroke.s3 {
    stroke-dasharray: 38;
    stroke-dashoffset: 38;
    animation-delay: 0.58s;
  }
  @keyframes draw { to { stroke-dashoffset: 0; } }

  /* ── Textos (reveal con máscara) ── */
  .intro-kicker {
    margin-top: 1.75rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(226, 232, 255, 0.85);
    opacity: 0;
    transform: translateY(12px);
    animation: riseIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) 1.05s forwards;
  }
  .intro-title {
    margin-top: 0.6rem;
    max-width: 22ch;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 300;
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: #fff;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.5);
    opacity: 0;
    transform: translateY(14px);
    animation: riseIn 1s cubic-bezier(0.16, 1, 0.3, 1) 1.25s forwards;
  }
  @keyframes riseIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Pista de scroll ── */
  .intro-hint {
    margin-top: 2.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: rgba(226, 232, 255, 0.7);
    opacity: 0;
    animation: riseIn 1s ease 1.8s forwards;
  }
  .intro-hint-text {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .intro-hint-arrow {
    width: 22px;
    height: 22px;
    animation: bob 1.8s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%      { transform: translateY(6px); opacity: 1; }
  }

  /* ── Partículas ── */
  .particle {
    position: absolute;
    bottom: -12px;
    width: 4px; height: 4px;
    border-radius: 9999px;
    background: rgba(190, 205, 255, 0.9);
    box-shadow: 0 0 10px rgba(150, 170, 255, 0.7);
    opacity: 0;
    animation: floatUp 10s linear infinite;
    pointer-events: none;
  }
  @keyframes floatUp {
    0%   { transform: translateY(0) scale(1);   opacity: 0; }
    12%  { opacity: 0.8; }
    88%  { opacity: 0.4; }
    100% { transform: translateY(-72vh) scale(0.5); opacity: 0; }
  }

  /* ── Sin movimiento: foto fija, sin parallax ni partículas, todo visible ── */
  @media (prefers-reduced-motion: reduce) {
    .intro-logo { animation: none; }
    .intro-stroke { animation: none; stroke-dashoffset: 0; }
    .intro-kicker, .intro-title, .intro-hint { animation: none; opacity: 1; transform: none; }
    .particle, .intro-hint-arrow { animation: none; }
    .particle { display: none; }
    #intro-photo { transform: scale(1.02); }
  }
</style>

<script>
  // Parallax de la portada: la foto se mueve con el puntero y, al hacer scroll,
  // se desplaza un poco más lenta que la web que la cubre (profundidad).
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const photo = document.getElementById("intro-photo") as HTMLImageElement | null;

  // Solo parallax de PUNTERO (no se mueve con el scroll, queda fija detrás).
  if (photo && !prefersReduced && window.matchMedia("(pointer: fine)").matches) {
    let mx = 0, my = 0;
    const apply = () => {
      photo.style.transform =
        `scale(1.14) translate3d(${(mx * 16).toFixed(1)}px, ${(my * 16).toFixed(1)}px, 0)`;
    };
    window.addEventListener("pointermove", (e) => {
      mx = (e.clientX / window.innerWidth) - 0.5;
      my = (e.clientY / window.innerHeight) - 0.5;
      apply();
    }, { passive: true });
    apply();
  }
</script>
