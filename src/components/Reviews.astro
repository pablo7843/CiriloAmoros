---
import { reviews, googleSummary } from "../data/reviews";
import { site } from "../data/site";
import Stars from "./Stars.astro";

const hasBusinessUrl = !googleSummary.businessUrl.startsWith("[PENDIENTE");
const ratingDisplay  = googleSummary.rating.toFixed(1).replace(".", ",");

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString("es-ES", { month: "long", year: "numeric" });
}
---

<section aria-labelledby="resenas-titulo" class="bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">

    <!-- Cabecera -->
    <div class="mb-14 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between" data-reveal>
      <div>
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Lo que dicen nuestros clientes</p>
        <h2
          id="resenas-titulo"
          class="headline text-4xl leading-[1.08] text-gray-900 sm:text-5xl"
        >
          Opiniones reales.<br />
          <span class="text-gray-400">{ratingDisplay} sobre 5 en Google.</span>
        </h2>
      </div>

      <!-- Badge Google -->
      {hasBusinessUrl ? (
        <a
          href={googleSummary.businessUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex shrink-0 items-center gap-3 rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm transition-shadow hover:shadow-md"
          aria-label="Ver el perfil de Google"
        >
          <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <div>
            <p class="flex items-center gap-1.5 text-sm font-semibold text-gray-900">
              <Stars rating={googleSummary.rating} class="h-3.5 w-3.5" />
              {ratingDisplay}
            </p>
            <p class="text-xs text-gray-500">Valoración en Google</p>
          </div>
          <svg class="h-4 w-4 text-gray-300 transition-colors group-hover:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
          </svg>
        </a>
      ) : (
        <div class="inline-flex shrink-0 items-center gap-3 rounded-2xl border border-gray-200 bg-white px-5 py-4">
          <div>
            <p class="flex items-center gap-1.5 text-sm font-semibold text-gray-900">
              <Stars rating={googleSummary.rating} class="h-3.5 w-3.5" />
              {ratingDisplay}
            </p>
            <p class="text-xs text-gray-500">Valoración en Google</p>
          </div>
        </div>
      )}
    </div>

    {reviews.length > 0 ? (
      <!-- Pull quote destacado (primera reseña larga) -->
      {reviews.filter(r => r.text.length > 60).slice(0, 1).map(r => (
        <div class="pullquote relative mb-16 pl-8" data-scrub data-scrub-span="0.5">
          <!-- Barra de acento que crece de arriba a abajo con el scroll -->
          <span class="pullquote-bar absolute left-0 top-0 w-0.5 origin-top rounded-full bg-accent-500" aria-hidden="true"></span>
          <p class="headline text-2xl leading-snug text-gray-900 sm:text-3xl lg:text-4xl lg:max-w-4xl">
            "{r.text}"
          </p>
          <div class="mt-5 flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-100 text-sm font-bold text-accent-700 shrink-0">
              {r.author.charAt(0)}
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900">{r.author}</p>
              <div class="flex gap-0.5 mt-0.5" aria-label={`${r.rating} estrellas`}>
                {Array.from({ length: 5 }, (_, i) => (
                  <svg class={`h-3.5 w-3.5 ${i < r.rating ? "text-yellow-400" : "text-gray-200"}`} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/>
                  </svg>
                ))}
              </div>
            </div>
            <span class="text-xs text-gray-400">· Google</span>
          </div>
        </div>
      ))}

      <!-- Rejilla de reseñas -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {reviews.map((review) => (
          <article data-tilt class="relative flex flex-col overflow-hidden rounded-2xl bg-white p-7 shadow-sm ring-1 ring-gray-200/60">
            <!-- Comilla decorativa -->
            <span
              class="pointer-events-none absolute -top-2 -left-1 select-none text-[7rem] leading-none text-gray-100 font-serif"
              aria-hidden="true"
            >"</span>

            <!-- Estrellas individuales -->
            <div class="mb-4 flex gap-0.5" aria-label={`${review.rating} estrellas`}>
              {Array.from({ length: 5 }, (_, i) => (
                <svg
                  class={`h-4 w-4 ${i < review.rating ? "text-yellow-400" : "text-gray-200"}`}
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/>
                </svg>
              ))}
            </div>

            <!-- Texto de la reseña -->
            <p class="relative z-10 flex-1 text-[15px] leading-relaxed text-gray-700">
              "{review.text}"
            </p>

            <!-- Autor + fecha -->
            <div class="mt-6 flex items-center justify-between border-t border-gray-100 pt-5">
              <div class="flex items-center gap-2.5">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-100 text-sm font-bold text-accent-700">
                  {review.author.charAt(0).toUpperCase()}
                </div>
                <p class="text-sm font-semibold text-gray-900">{review.author}</p>
              </div>
              <p class="text-xs text-gray-400">{formatDate(review.date)}</p>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <!-- Estado sin reseñas -->
      <div class="rounded-2xl border border-dashed border-gray-300 bg-white px-8 py-12 text-center">
        <p class="text-sm font-medium text-gray-500">
          [PENDIENTE: añadir 4–6 reseñas reales desde el perfil de Google Business en <code class="rounded bg-gray-100 px-1 text-xs">src/data/reviews.ts</code>]
        </p>
        <p class="mt-2 text-xs text-gray-400">Regla del proyecto: no inventar ni modificar reseñas. Solo texto real copiado de Google.</p>
      </div>
    )}

    {hasBusinessUrl && (
      <div class="mt-10 text-center">
        <a
          href={googleSummary.businessUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 transition-colors hover:text-gray-800"
        >
          Ver todas las reseñas en Google
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .pullquote { --p: 1; }
  .pullquote-bar {
    height: 100%;
    transform: scaleY(var(--p));
    box-shadow: 0 0 10px rgba(82, 102, 235, 0.4);
    will-change: transform;
  }
</style>
