const RULES: [RegExp, string][] = [
  [/(24|acceso|llave\b)/, "clock"],
  [/llave/, "key"],
  [/(internet|wifi|fibra|red\b)/, "wifi"],
  [/limpieza/, "sparkles"],
  [/(climatiz|aire|calefac|temperat)/, "thermo"],
  [/videoconfer/, "video"],
  [/(proyector|pantalla|presentaci)/, "presentation"],
  [/(sala|reunion|reuni)/, "group"],
  [/(recep|visita|atenci|telef)/, "user"],
  [/(direccion|postal|fiscal|domicil|comercial)/, "mappin"],
  [/(correo|paquet|envio)/, "envelope"],
  [/(cafe|agua|infusi|\bte\b)/, "cup"],
  [/(bici|aparca|parking)/, "bike"],
  [/(zona|comun|cocina|office|descanso)/, "home"],
  [/(permanencia|contrato|plan\b)/, "doc"],
  [/metro|transporte/, "mappin"],
];

let name = "check";
// "llave" debe ganar a la regla de "acceso"; comprobamos llave primero
if (/llave/.test(norm)) name = "key";
else {
  for (const [re, n] of RULES) {
    if (re.test(norm)) { name = n; break; }
  }
}
const inner = ICONS[name] ?? ICONS.check;
---

<svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true" set:html={inner} />
