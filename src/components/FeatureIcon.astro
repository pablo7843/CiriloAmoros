  bike: `<path stroke-linecap="round" stroke-linejoin="round" d="M5.25 18a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Zm13.5 0a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5ZM5.25 15.75 9 8.25h4.5l3.75 7.5M9 8.25l3 7.5M13.5 8.25h2.25"/>`,
  home: `<path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.95-8.95c.44-.44 1.15-.44 1.6 0L21.75 12M4.5 9.75v10.13c0 .62.5 1.12 1.13 1.12H9.75V16.1c0-.62.5-1.13 1.13-1.13h2.25c.62 0 1.12.5 1.12 1.13V21h4.13c.62 0 1.12-.5 1.12-1.12V9.75"/>`,
  doc: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.63a3.38 3.38 0 0 0-3.38-3.37h-1.5a1.12 1.12 0 0 1-1.12-1.13v-1.5A3.38 3.38 0 0 0 10.12 2.25H8.25M10.5 2.25H5.63c-.62 0-1.13.5-1.13 1.13v17.25c0 .62.5 1.12 1.13 1.12h12.75c.62 0 1.12-.5 1.12-1.12V11.25a9 9 0 0 0-9-9Z"/>`,
  check: `<path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>`,
