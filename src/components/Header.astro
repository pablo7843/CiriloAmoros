---
import { site } from "../data/site";
import { mainNav } from "../data/navigation";
import MobileMenu from "./MobileMenu.svelte";

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/" || pathname === "";
  return pathname === href || pathname === href + "/" || pathname.startsWith(href + "/");
}

const navLinks = mainNav.filter((l) => !l.highlight);
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-gray-200/80 bg-white/95 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-6 px-6">

    <!-- Logo -->
    <a
      href="/"
      class="shrink-0 flex items-center gap-2.5"
      aria-label="Inicio — Cirilo Amorós Centro Empresarial"
    >
      <!-- Icono del logo (inline SVG para control total del color) -->
      <svg
        class="h-7 w-7 shrink-0 text-gray-900"
        viewBox="0 0 52 52"
        fill="none"
        aria-hidden="true"
      >
        <path d="M17 5 L5 5 L5 47 L17 47" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M35 5 L47 5 L47 47 L35 47" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        <line x1="26" y1="10" x2="26" y2="42" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
      </svg>
      <span class="leading-tight">
        <span class="block text-[15px] font-semibold tracking-tight text-gray-900">
          Cirilo Amorós
        </span>
        <span class="block text-[11px] text-gray-400">Centro Empresarial · Valencia</span>
      </span>
    </a>

    <!-- Navegación desktop -->
    <nav
      class="hidden lg:flex flex-1 items-center gap-1"
      aria-label="Navegación principal"
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class={[
              "rounded-full px-3.5 py-2 text-sm font-medium transition-colors",
              isActive(link.href)
                ? "bg-gray-100 text-gray-900"
                : "text-gray-600 hover:bg-gray-50 hover:text-gray-900",
            ].join(" ")}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Right: teléfono + CTA + menú móvil -->
    <div class="flex shrink-0 items-center gap-2">
      <!-- Teléfono — visible desde md -->
      <a
        href={site.contact.phoneHref}
        class="hidden md:inline-flex items-center gap-1.5 rounded-full px-3.5 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-50 hover:text-gray-900"
        aria-label={`Llamar al ${site.contact.phone}`}
      >
        <svg
          class="h-4 w-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
          ></path>
        </svg>
        {site.contact.phone}
      </a>

      <!-- Botón Contactar — visible desde sm -->
      <a
        href="/contacto"
        class="hidden sm:inline-flex items-center rounded-full bg-accent-600 px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2"
      >
        Contactar
      </a>

      <!-- Menú móvil (isla Svelte — solo hasta lg) -->
      <div class="lg:hidden">
        <MobileMenu
          client:load
          navLinks={mainNav}
          phone={site.contact.phone}
          phoneHref={site.contact.phoneHref}
          email={site.contact.email}
          emailHref={site.contact.emailHref}
          currentPath={pathname}
        />
      </div>
    </div>
  </div>
</header>

<!-- Espaciador para compensar el header fijo -->
<div class="h-16" aria-hidden="true"></div>
