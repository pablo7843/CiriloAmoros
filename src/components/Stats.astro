---
import { site } from "../data/site";

const years  = new Date().getFullYear() - site.founded;
const rating = site.google.rating;

const stats = [
  {
    display:  `${years}`,
    unit:     "años",
    desc:     "en el centro de Valencia",
    countTo:  years,
    decimals: 0,
  },
  {
    display:  rating.toFixed(1).replace(".", ","),
    unit:     "★",
    desc:     "valoración en Google",
    countTo:  rating,
    decimals: 1,
  },
  {
    display:  "3",
    unit:     "min",
    desc:     "al metro Xàtiva a pie",
    countTo:  3,
    decimals: 0,
  },
  {
    display:  "24/7",
    unit:     "",
    desc:     "acceso para clientes",
    countTo:  null,   // no animable
    decimals: 0,
  },
];
---

<section
  id="stats-section"
  aria-label="Cifras del centro"
  class="overflow-hidden border-y border-gray-100 bg-white"
>
  <div class="stats-band relative mx-auto max-w-7xl" data-scrub>
    <!-- Barra de acento que se dibuja con el scroll -->
    <span class="stats-line absolute inset-x-0 top-0 h-0.5 origin-left bg-gradient-to-r from-accent-500 to-accent-300" aria-hidden="true"></span>
    <dl class="grid grid-cols-2 divide-x divide-y divide-gray-100 lg:grid-cols-4 lg:divide-y-0">
      {stats.map((s) => (
        <div class="flex flex-col items-start gap-1 px-8 py-10 sm:px-10 sm:py-12">
          <dt class="order-last text-xs font-semibold uppercase tracking-[0.15em] text-gray-400">
            {s.desc}
          </dt>
          <dd class="flex items-baseline gap-1 leading-none">
            <span
              class="text-[3.25rem] font-light tracking-[0.01em] text-gray-900 sm:text-[3.75rem] lg:text-[4.25rem]"
              data-count-to={s.countTo !== null ? s.countTo : undefined}
              data-decimals={s.decimals}
            >
              {s.display}
            </span>
            {s.unit === "★" ? (
              <svg class="h-7 w-7 self-center text-yellow-400 sm:h-8 sm:w-8" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/>
              </svg>
            ) : s.unit && (
              <span class="text-2xl font-light text-accent-500 sm:text-3xl">{s.unit}</span>
            )}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .stats-band { --p: 1; }
  .stats-line {
    transform: scaleX(var(--p));
    box-shadow: 0 0 10px rgba(82, 102, 235, 0.45);
    will-change: transform;
  }
</style>
