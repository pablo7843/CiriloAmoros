---
import { site } from "../data/site";
import Aurora from "./Aurora.astro";

const hasWhatsApp = !site.contact.whatsapp.startsWith("[PENDIENTE");
---

<section aria-label="Contacto — sección final" class="overflow-hidden bg-white">

  <!-- Separador visual -->
  <div class="mx-auto max-w-7xl px-6">
    <div class="h-px bg-gray-200" aria-hidden="true"></div>
  </div>

  <div class="relative overflow-hidden bg-gray-950 py-24 sm:py-32">
    <Aurora tone="dark" />
    <div class="relative z-10 mx-auto max-w-7xl px-6">

      <div class="grid grid-cols-1 gap-14 lg:grid-cols-2 lg:items-center lg:gap-20" data-reveal>

        <!-- Columna izquierda: titular editorial -->
        <div>
          <p class="mb-4 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-400">Empieza hoy</p>
          <h2 data-split class="headline text-4xl leading-[1.06] text-white sm:text-5xl xl:text-6xl">
            Tu despacho<br />en Valencia centro<br />te está esperando.
          </h2>
          <p class="mt-6 max-w-md text-[15px] leading-relaxed text-gray-400">
            Visitamos las instalaciones juntos, sin presiones. Te explicamos qué incluye cada plan
            y te reservamos el espacio que mejor encaje contigo.
          </p>

          <!-- Característica rápida -->
          <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3">
            {[
              "Sin permanencia larga",
              "Acceso 24/7",
              "Todo incluido",
            ].map((feat) => (
              <div class="flex items-center gap-2 text-sm text-gray-400">
                <svg class="h-4 w-4 shrink-0 text-accent-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
                </svg>
                {feat}
              </div>
            ))}
          </div>
        </div>

        <!-- Columna derecha: tarjeta de contacto -->
        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-8 sm:p-10">

          <!-- Teléfono destacado -->
          <div class="mb-8 border-b border-gray-800 pb-8">
            <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500">Llámanos ahora</p>
            <a
              href={site.contact.phoneHref}
              class="group inline-flex items-baseline gap-2 text-3xl font-light tracking-[0.01em] text-white transition-colors hover:text-accent-400 sm:text-4xl"
            >
              {site.contact.phone}
              <svg class="h-5 w-5 self-center text-gray-600 transition-colors group-hover:text-accent-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
              </svg>
            </a>
            <p class="mt-1.5 text-xs text-gray-500">
              {site.schedule.weekdays !== "[PENDIENTE: horario L–V, p. ej. 09:00–19:00]"
                ? `Atención: ${site.schedule.weekdays}`
                : "Atención de lunes a viernes en horario de oficina"}
            </p>
          </div>

          <!-- Otras vías -->
          <div class="space-y-4">
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500">O escríbenos</p>

            <!-- Botón CTA principal -->
            <a
              href="/contacto?motivo=visita"
              class="flex w-full items-center justify-center rounded-full bg-accent-600 px-6 py-4 text-sm font-medium text-white
                     transition-colors hover:bg-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-gray-900"
            >
              Solicitar visita sin compromiso
            </a>

            <!-- WhatsApp (solo si está configurado) -->
            {hasWhatsApp && (
              <a
                href={site.contact.whatsappHref}
                target="_blank"
                rel="noopener noreferrer"
                class="flex w-full items-center justify-center gap-2.5 rounded-full border border-gray-700 bg-gray-800 px-6 py-3.5
                       text-sm font-medium text-gray-300 transition-colors hover:border-gray-600 hover:text-white
                       focus:outline-none focus:ring-2 focus:ring-gray-600 focus:ring-offset-2 focus:ring-offset-gray-900"
              >
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
                WhatsApp
              </a>
            )}

            <!-- Email directo -->
            <div class="flex items-center justify-center gap-1.5 text-xs text-gray-600">
              <span>O por email a</span>
              <a
                href={site.contact.emailHref}
                class="font-medium text-gray-400 transition-colors hover:text-white"
              >
                {site.contact.email}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
