---
import { site } from "../data/site";

const distances = [
  { place: "Metro Xàtiva",         detail: "Líneas L3 · L5 · L9", minutes: 3,  accent: true  },
  { place: "Calle Colón",          detail: "Zona comercial",  minutes: 5,  accent: false },
  { place: "Plaza del Ayuntamiento", detail: "",             minutes: 8,  accent: false },
  { place: "Estación del Norte",   detail: "",               minutes: 12, accent: false },
];

const busLines = ["11", "13", "32", "79", "95"];

const hasMapsUrl    = !site.google.mapsUrl.startsWith("[PENDIENTE");
const hasEmbedSrc   = !site.google.mapsEmbedSrc.startsWith("[PENDIENTE");
---

<section aria-labelledby="ubicacion-titulo" class="overflow-hidden bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">

    <div class="mb-14" data-reveal>
      <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Ubicación</p>
      <h2
        id="ubicacion-titulo"
        data-split
        class="headline text-4xl leading-[1.08] text-gray-900 sm:text-5xl"
      >
        En el corazón<br />de Valencia.
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_360px]" data-reveal style="transition-delay: 100ms">

      <!-- ── Mapa ── -->
      <div class="relative overflow-hidden rounded-2xl bg-gray-200 aspect-[4/3] lg:aspect-auto lg:min-h-[520px]">

        {hasEmbedSrc ? (
          <iframe
            src={site.google.mapsEmbedSrc}
            width="100%"
            height="100%"
            class="absolute inset-0 border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Cirilo Amorós Centro Empresarial en Google Maps"
          />
        ) : (
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 select-none" aria-hidden="true">
            <svg class="absolute inset-0 h-full w-full opacity-[0.06]" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="mapgrid" width="44" height="44" patternUnits="userSpaceOnUse">
                  <path d="M 44 0 L 0 0 0 44" fill="none" stroke="#000" stroke-width="1"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#mapgrid)"/>
            </svg>
            <div class="relative z-10 flex flex-col items-center gap-2 text-center">
              <div class="flex h-11 w-11 items-center justify-center rounded-full bg-accent-600 shadow-lg">
                <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-2.079 3.953-5.159 3.953-8.827a8.25 8.25 0 0 0-16.5 0c0 3.668 2.009 6.748 3.953 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd"/>
                </svg>
              </div>
              <p class="text-sm font-semibold text-gray-700">C/ Cirilo Amorós 6</p>
              <p class="text-xs text-gray-400">[Pendiente: embed de Google Maps]</p>
            </div>
          </div>
        )}

        <!-- Barra de dirección anclada al fondo -->
        <div class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-4 bg-white/95 px-5 py-4 backdrop-blur-sm">
          <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-gray-900">{site.address.street}</p>
            <p class="text-xs text-gray-500">{site.address.access} · {site.address.postalCode} {site.address.city}</p>
          </div>
          {hasMapsUrl && (
            <a
              href={site.google.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 text-xs font-semibold text-accent-600 transition-colors hover:text-accent-700"
            >
              Ver mapa →
            </a>
          )}
        </div>
      </div>

      <!-- ── Panel de información ── -->
      <div class="flex flex-col gap-10 lg:pt-2">

        <!-- Distancias a pie -->
        <div>
          <p class="mb-5 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400">A pie desde aquí</p>
          <ul>
            {distances.map((d, i) => (
              <li class={`flex items-center justify-between py-4 ${i < distances.length - 1 ? "border-b border-gray-200" : ""}`}>
                <div>
                  <p class={`text-sm ${d.accent ? "font-semibold text-gray-900" : "text-gray-700"}`}>{d.place}</p>
                  {d.detail && <p class="mt-0.5 text-xs text-gray-400">{d.detail}</p>}
                </div>
                <div class="flex shrink-0 items-center gap-1.5 pl-4">
                  <svg class="h-3.5 w-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z" />
                  </svg>
                  <span class={`text-sm font-semibold tabular-nums ${d.accent ? "text-accent-600" : "text-gray-500"}`}>
                    {d.minutes} min
                  </span>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Transporte público -->
        <div>
          <p class="mb-5 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400">Transporte público</p>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <span class="w-10 shrink-0 text-xs font-bold text-gray-400">Metro</span>
              <span class="inline-flex items-center rounded-md bg-orange-50 px-2.5 py-1 text-xs font-bold text-orange-700 ring-1 ring-inset ring-orange-600/20">L3</span>
              <span class="inline-flex items-center rounded-md bg-green-50 px-2.5 py-1 text-xs font-bold text-green-700 ring-1 ring-inset ring-green-600/20">L5</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-10 shrink-0 pt-1 text-xs font-bold text-gray-400">Bus</span>
              <div class="flex flex-wrap gap-1.5">
                {busLines.map((l) => (
                  <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-xs font-semibold text-blue-700 ring-1 ring-inset ring-blue-700/15">{l}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

        {hasMapsUrl ? (
          <a
            href={site.google.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 text-sm font-semibold text-gray-700 transition-colors hover:text-accent-600"
          >
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
            Abrir en Google Maps
            <svg class="h-3.5 w-3.5 text-gray-400 transition-colors group-hover:text-accent-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
            </svg>
          </a>
        ) : (
          <p class="text-xs italic text-gray-400">[PENDIENTE: añadir URL de Google Maps en site.ts]</p>
        )}
      </div>
    </div>
  </div>
</section>
