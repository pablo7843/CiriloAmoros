---
import { cownord } from "../data/cownord";
import type { CownordCenter } from "../data/cownord";
import Aurora from "./Aurora.astro";
import Stars from "./Stars.astro";
import Amenities from "./Amenities.astro";
import ShowcaseBand from "./ShowcaseBand.astro";
import Faq from "./Faq.astro";

interface Props { center: CownordCenter }
const { center } = Astro.props;

const isPending = (v: string | number | null | undefined) =>
  v == null || (typeof v === "string" && v.startsWith("[PENDIENTE"));

const hasEmbed = !isPending(center.address.mapsEmbedSrc);
const addrLine = [center.address.street, center.address.city].filter(Boolean).join(", ");
const transportHint = center.id === "massamagrell"
  ? "Junto al metro de Massamagrell"
  : "A 4 minutos del metro";

// FAQ genérica (hechos reales conocidos de Cownord)
const faqs = [
  { q: "¿Tengo acceso fuera del horario de oficina?", a: "Sí. El acceso es 24/7 los 365 días mediante la app móvil." },
  { q: "¿Hay permanencia?", a: "Los puestos flexibles se reservan por horas o por días, sin permanencia. Para puestos fijos y despachos, consúltanos las condiciones." },
  { q: "¿Puedo visitar el espacio antes de contratar?", a: "Por supuesto. Escríbenos o llámanos y concertamos una visita sin compromiso." },
];
---

<!-- ── Hero (foto real a sangre) ── -->
<section class="relative flex min-h-[88svh] items-center justify-center overflow-hidden">
  <img
    src={center.image}
    alt={`Espacio de coworking Cownord en ${center.city}`}
    class="absolute inset-0 h-full w-full object-cover"
    fetchpriority="high"
    decoding="async"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-gray-950/75 via-gray-950/55 to-gray-950/85"></div>

  <div class="relative z-10 mx-auto max-w-3xl px-6 py-24 text-center" data-reveal>
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-3.5 py-1.5 text-xs font-medium text-white backdrop-blur-sm">
      Cownord · {center.kind} en {center.city}
    </div>
    <h1 class="headline text-[2.75rem] leading-[1.05] text-white sm:text-6xl">
      {center.headline}
    </h1>
    <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-gray-200 sm:text-lg">
      {center.intro}
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="#contacto" class="btn-primary shadow-lg">Reservar visita</a>
      <a href="#servicios" class="inline-flex items-center gap-1.5 rounded-full border border-white/30 bg-white/10 px-6 py-3 text-sm font-medium text-white backdrop-blur-sm transition-colors hover:bg-white/20">
        Ver servicios y precios
      </a>
    </div>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm font-medium text-gray-200">
      {center.access24h && (
        <span class="inline-flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-accent-400"></span>Acceso 24/7 los 365 días</span>
      )}
      {center.id === "massamagrell" && (
        <span class="inline-flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-accent-400"></span>A un paso del metro de Massamagrell</span>
      )}
    </div>
  </div>
</section>

<!-- ── Servicios ── -->
<section id="servicios" class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto mb-14 max-w-2xl text-center" data-reveal>
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent-600">Servicios</p>
      <h2 class="headline text-3xl text-gray-900 sm:text-4xl">Espacios que se adaptan a ti</h2>
    </div>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {center.services.map((s, i) => (
        <article data-reveal data-tilt style={`transition-delay: ${i * 100}ms`}
          class="flex flex-col rounded-2xl border border-gray-200 bg-white p-7 transition-shadow hover:shadow-lg">
          <h3 class="text-lg font-medium text-gray-900">{s.name}</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-500">{s.desc}</p>
          <p class="mt-4 text-sm">
            {isPending(s.priceFrom)
              ? <span class="italic text-gray-400">Precio: a confirmar</span>
              : <><span class="text-2xl font-light tracking-[0.01em] text-gray-900">{s.priceFrom}</span></>}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ── Servicios e instalaciones (iconos circulares) ── -->
<Amenities eyebrow="Todo incluido" title="Servicios e instalaciones del centro" />

<!-- ── Ubicación ── -->
<section class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-14" data-reveal>
      <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Ubicación</p>
      <h2 class="headline text-4xl leading-[1.08] text-gray-900 sm:text-5xl">En {center.city}.</h2>
    </div>
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_380px]" data-reveal style="transition-delay: 100ms">

      <!-- Mapa -->
      <div class="relative overflow-hidden rounded-2xl bg-gray-200 aspect-[4/3] lg:aspect-auto lg:min-h-[480px]">
        {hasEmbed && (
          <iframe src={center.address.mapsEmbedSrc} width="100%" height="100%" class="absolute inset-0 border-0"
            loading="lazy" referrerpolicy="no-referrer-when-downgrade" title={`Ubicación de ${center.name}`} />
        )}
        <div class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-4 bg-white/95 px-5 py-4 backdrop-blur-sm">
          <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-gray-900">{center.address.street}</p>
            <p class="text-xs text-gray-500">
              {isPending(center.address.postalCode) ? "" : center.address.postalCode + " "}{center.address.city}
            </p>
          </div>
          <a href={center.address.mapsUrl} target="_blank" rel="noopener noreferrer"
            class="shrink-0 text-xs font-semibold text-accent-600 transition-colors hover:text-accent-700">Ver mapa →</a>
        </div>
      </div>

      <!-- Panel de información -->
      <div class="flex flex-col gap-8 lg:pt-2">
        <div>
          <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400">Dirección</p>
          <p class="text-sm text-gray-700">{addrLine}</p>
        </div>
        <div>
          <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400">Horario</p>
          <p class="inline-flex items-center gap-2 text-sm font-medium text-gray-900">
            <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>{center.schedule}
          </p>
        </div>
        <div>
          <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400">Cómo llegar</p>
          <div class="flex items-center gap-3 rounded-xl bg-accent-50 px-4 py-3 text-sm font-medium text-accent-700 ring-1 ring-accent-100">
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z" />
            </svg>
            {transportHint}
          </div>
        </div>
        <a href={center.address.mapsUrl} target="_blank" rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-gray-700 transition-colors hover:text-accent-600">
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
          </svg>
          Abrir en Google Maps
          <svg class="h-3.5 w-3.5 text-gray-400 transition-colors group-hover:text-accent-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ── Reseñas (solo si hay reales) ── -->
{center.reviews.length > 0 && (
<section class="bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between" data-reveal>
      <h2 class="headline text-4xl leading-[1.08] text-gray-900 sm:text-5xl">Opiniones reales.</h2>
      {!isPending(center.rating) && (
        <span class="inline-flex items-center gap-2 rounded-2xl border border-gray-200 bg-white px-5 py-3 text-sm font-semibold text-gray-900">
          <Stars rating={center.rating ?? 5} class="h-4 w-4" /> {center.rating}
        </span>
      )}
    </div>
    {center.reviews.length > 0 ? (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {center.reviews.map((r) => (
          <article data-tilt class="rounded-2xl bg-white p-7 shadow-sm ring-1 ring-gray-200/60">
            <Stars rating={r.rating} class="h-4 w-4" />
            <p class="mt-4 text-[15px] leading-relaxed text-gray-700">"{r.text}"</p>
            <p class="mt-5 text-sm font-semibold text-gray-900">{r.author}</p>
          </article>
        ))}
      </div>
    ) : (
      <div class="rounded-2xl border border-dashed border-gray-300 bg-white px-8 py-12 text-center" data-reveal>
        <p class="text-sm font-medium text-gray-500">
          [PENDIENTE: pegar 4–6 reseñas reales de Google de la sede de {center.city} + nota media]
        </p>
        <p class="mt-2 text-xs text-gray-400">Regla del proyecto: solo reseñas reales verificadas.</p>
      </div>
    )}
  </div>
</section>
)}

<!-- ── CTA chat IA (ambas sedes) ── -->
<Faq />

<!-- ── CTA + cross-link a Cirilo ── -->
<section id="contacto" class="scroll-mt-20 overflow-hidden bg-white">
  <div class="relative overflow-hidden bg-gray-950 py-24 sm:py-32">
    <Aurora tone="dark" />
    <div class="relative z-10 mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 gap-14 lg:grid-cols-2 lg:items-center" data-reveal>
        <div>
          <h2 class="headline text-4xl leading-[1.06] text-white sm:text-5xl">Ven a conocer<br />Cownord {center.city}.</h2>
          <p class="mt-6 max-w-md text-[15px] leading-relaxed text-gray-400">
            Te enseñamos el espacio sin compromiso y te explicamos las modalidades. Acceso 24/7.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-8 sm:p-10">
          <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500">Llámanos</p>
          <a href={center.contact.phoneHref} class="block text-3xl font-light tracking-[0.01em] text-white transition-colors hover:text-accent-400">
            {center.contact.phone}
          </a>
          <a href={center.contact.emailHref} class="mt-6 flex w-full items-center justify-center rounded-full bg-accent-600 px-6 py-4 text-sm font-medium text-white transition-colors hover:bg-accent-700">
            Escríbenos a {center.contact.email}
          </a>
          <!-- Cross-link a la otra marca del grupo -->
          <a href={cownord.cirilo.url} class="mt-4 flex items-center justify-between gap-3 rounded-full border border-gray-700 px-5 py-3 text-sm text-gray-300 transition-colors hover:border-gray-500 hover:text-white">
            <span>{cownord.cirilo.pitch}</span>
            <span class="shrink-0 font-medium">Cirilo Amorós ↗</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
