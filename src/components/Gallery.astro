---
/**
 * Galería de espacios — diseño asimétrico tipo revista.
 * Reemplazar los placeholders con imágenes reales en /public/images/.
 */
const cells = [
  { src: "/images/galeria-recepcion.jpg",     alt: "Recepción y zona de entrada del centro",            label: "Recepción"          },
  { src: "/images/galeria-despacho.jpg",      alt: "Despacho privado totalmente equipado",              label: "Despacho privado"   },
  { src: "/images/galeria-sala.jpg",          alt: "Sala de reuniones con pantalla y videoconferencia", label: "Sala de reuniones"  },
  { src: "/images/galeria-comun.jpg",         alt: "Zona común y de descanso",                          label: "Zona común"         },
  { src: "/images/galeria-exterior.jpg",      alt: "Pasaje Ruzafa — acceso al centro",                  label: "Acceso"             },
];
---

<section aria-labelledby="galeria-titulo" class="bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-6">

    <!-- Cabecera -->
    <div class="mb-10 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between" data-reveal>
      <div>
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Las instalaciones</p>
        <h2
          id="galeria-titulo"
          class="text-4xl font-bold leading-[1.08] tracking-tight text-gray-900 sm:text-5xl"
        >
          Espacios pensados<br />para trabajar bien.
        </h2>
      </div>
      <p class="max-w-xs text-sm leading-relaxed text-gray-500 sm:text-right">
        Diseño contemporáneo, luz natural y todo lo que necesita desde el primer día.
      </p>
    </div>

    <!-- Grid asimétrico principal: celda grande (izquierda) + 2 pequeñas (derecha) -->
    <div class="grid grid-cols-2 gap-3 lg:grid-cols-[1.6fr_1fr] lg:grid-rows-2 lg:h-[540px]" data-reveal style="transition-delay: 100ms">

      <!-- Celda grande — filas 1 y 2 -->
      <div class="relative col-span-2 overflow-hidden rounded-2xl bg-gray-100 lg:col-span-1 lg:row-span-2 aspect-[4/3] lg:aspect-auto">
        <img
          src={cells[0].src}
          alt={cells[0].alt}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-[1.03]"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-center" aria-hidden="true">
          <svg class="h-8 w-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
          </svg>
          <p class="text-xs text-gray-400">{cells[0].label}<br /><span class="text-gray-300">[foto pendiente]</span></p>
        </div>
        <!-- Etiqueta -->
        <div class="absolute bottom-3 left-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-700 backdrop-blur-sm">
          {cells[0].label}
        </div>
      </div>

      <!-- Celda 2 (arriba derecha) -->
      <div class="relative overflow-hidden rounded-2xl bg-gray-100 aspect-[4/3] lg:aspect-auto">
        <img
          src={cells[1].src}
          alt={cells[1].alt}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-[1.03]"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-center" aria-hidden="true">
          <svg class="h-6 w-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
          </svg>
          <p class="text-xs text-gray-400">{cells[1].label}</p>
        </div>
        <div class="absolute bottom-3 left-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-700 backdrop-blur-sm">
          {cells[1].label}
        </div>
      </div>

      <!-- Celda 3 (abajo derecha) -->
      <div class="relative overflow-hidden rounded-2xl bg-gray-100 aspect-[4/3] lg:aspect-auto">
        <img
          src={cells[2].src}
          alt={cells[2].alt}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-[1.03]"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-center" aria-hidden="true">
          <svg class="h-6 w-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
          </svg>
          <p class="text-xs text-gray-400">{cells[2].label}</p>
        </div>
        <div class="absolute bottom-3 left-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-700 backdrop-blur-sm">
          {cells[2].label}
        </div>
      </div>
    </div>

    <!-- Segunda fila: 2 celdas medianas -->
    <div class="mt-3 grid grid-cols-2 gap-3 h-48 sm:h-56">
      {cells.slice(3).map((cell) => (
        <div class="relative overflow-hidden rounded-2xl bg-gray-100">
          <img
            src={cell.src}
            alt={cell.alt}
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-[1.03]"
            loading="lazy"
            decoding="async"
            onerror="this.style.display='none'"
          />
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-1.5 text-center" aria-hidden="true">
            <svg class="h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
            <p class="text-xs text-gray-400">{cell.label}</p>
          </div>
          <div class="absolute bottom-3 left-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-700 backdrop-blur-sm">
            {cell.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Nota sobre fotos -->
    <p class="mt-6 text-center text-xs text-gray-400">
      [Pendiente: añadir fotografías reales del espacio en <code class="rounded bg-gray-100 px-1">/public/images/</code>]
    </p>
  </div>
</section>
