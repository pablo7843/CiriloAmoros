---
import { site } from "../data/site";
import { services } from "../data/services";
import Stars from "./Stars.astro";

const rating    = site.google.rating.toFixed(1).replace(".", ",");
const priceFrom = services[0].priceFrom;

/**
 * Hero "vídeo por scroll" — sección alta (260vh) con contenido fijo (sticky).
 * La escena se dimensiona por aspect-ratio (--sceneH), así NUNCA se recorta.
 * Historia al bajar: la ciudad se construye (dos capas con profundidad) →
 * el edificio del centro se ilumina ventana a ventana y enciende su letrero
 * "CA" → se dibuja la ruta a pie con un punto que la recorre → aparecen los
 * chips de beneficios. Reversible (scrub ligado al scroll, como un vídeo).
 *
 * Variables de progreso (las fija el script en #hero-scrub):
 *   --pDraw  → construcción de la ciudad
 *   --pLight → luces, letrero CA, ruta, chips y viraje del cielo
 *   --pZoom  → zoom sutil de la escena
 *   --pText  → desvanecimiento del texto al final
 * Sin JS o con prefers-reduced-motion: escena completa y estática.
 */

// Capa trasera del skyline (profundidad — entra antes y se mueve menos)
const backBuildings = [
  { x: 80,   y: 250, w: 90,  h: 170 },
  { x: 210,  y: 220, w: 70,  h: 200 },
  { x: 330,  y: 270, w: 100, h: 150 },
  { x: 470,  y: 230, w: 60,  h: 190 },
  { x: 760,  y: 240, w: 80,  h: 180 },
  { x: 880,  y: 210, w: 90,  h: 210 },
  { x: 1010, y: 260, w: 70,  h: 160 },
  { x: 1110, y: 230, w: 80,  h: 190 },
];

// Capa delantera — d = retardo de aparición (0..0.3)
const buildings = [
  { x: 20,   y: 290, w: 100, h: 130, d: 0.00 },
  { x: 140,  y: 240, w: 80,  h: 180, d: 0.10 },
  { x: 240,  y: 280, w: 110, h: 140, d: 0.05 },
  { x: 370,  y: 200, w: 90,  h: 220, d: 0.16 },
  { x: 480,  y: 320, w: 50,  h: 100, d: 0.22 },
  { x: 700,  y: 250, w: 90,  h: 170, d: 0.08 },
  { x: 810,  y: 210, w: 120, h: 210, d: 0.18 },
  { x: 950,  y: 280, w: 80,  h: 140, d: 0.12 },
  { x: 1050, y: 240, w: 110, h: 180, d: 0.24 },
];

// Ventanas del edificio central (32) — se encienden escalonadas
const winCols = [559, 589, 619, 649];
const winRows = [102, 140, 178, 216, 254, 292, 330, 368];
const windows = winRows.flatMap((y, r) =>
  winCols.map((x, c) => ({ x, y, d: (((r * 7 + c * 5) % 12) / 12) * 0.72 }))
);

// Alguna ventana encendida en edificios vecinos (la ciudad está viva)
const cityWindows = [
  { x: 392,  y: 228, d: 0.80 },
  { x: 424,  y: 262, d: 0.90 },
  { x: 840,  y: 238, d: 0.84 },
  { x: 882,  y: 272, d: 0.94 },
];

// Chips de beneficios flotantes — aparecen con las luces
const chips = [
  { text: "Acceso 24/7",                side: "left",  bottom: 0.62, d: 0.55 },
  { text: `Desde ${priceFrom} €/mes`,   side: "right", bottom: 0.55, d: 0.72 },
];

// Partículas — más densidad, tamaños y ritmos variados
const particles = [
  { left: 8,  delay: 0.0, dur: 9,  size: 4 },
  { left: 16, delay: 3.1, dur: 11, size: 3 },
  { left: 27, delay: 1.4, dur: 8,  size: 5 },
  { left: 38, delay: 4.2, dur: 10, size: 3 },
  { left: 47, delay: 2.0, dur: 9,  size: 4 },
  { left: 58, delay: 5.0, dur: 12, size: 3 },
  { left: 66, delay: 0.8, dur: 8,  size: 5 },
  { left: 77, delay: 3.6, dur: 10, size: 4 },
  { left: 86, delay: 1.8, dur: 9,  size: 3 },
  { left: 94, delay: 4.6, dur: 11, size: 4 },
];
---

<section id="hero-scrub" aria-label="Presentación — Cirilo Amorós Centro Empresarial">
  <div
    class="hero-sticky sticky top-0 h-svh overflow-hidden bg-gradient-to-b from-slate-50 via-white to-accent-50"
  >

    <!-- Aurora de fondo -->
    <span class="hero-aurora hero-aurora--a" aria-hidden="true"></span>
    <span class="hero-aurora hero-aurora--b" aria-hidden="true"></span>

    <!-- Viraje del cielo al "atardecer" conforme se encienden las luces -->
    <div class="hero-skyshift absolute inset-0 bg-gradient-to-t from-accent-100/60 via-accent-50/20 to-transparent" aria-hidden="true"></div>

    <!-- Sol / halo tras el edificio central -->
    <span class="hero-sun" aria-hidden="true"></span>

    <!-- Partículas -->
    {particles.map((p) => (
      <span
        class="hero-particle"
        style={`left: ${p.left}%; animation-delay: ${p.delay}s; animation-duration: ${p.dur}s; width: ${p.size}px; height: ${p.size}px`}
        aria-hidden="true"
      ></span>
    ))}

    <!-- Escena: la ciudad que se construye. aspect-ratio → no se recorta nunca -->
    <div class="hero-scene pointer-events-none absolute inset-x-0 bottom-0 flex justify-center" aria-hidden="true">
      <svg
        class="block shrink-0"
        style="height: var(--sceneH); aspect-ratio: 1200 / 460"
        viewBox="0 0 1200 460"
        preserveAspectRatio="xMidYMax meet"
      >
        <!-- Capa trasera (profundidad) -->
        {backBuildings.map((b) => (
          <rect class="bldb" x={b.x} y={b.y} width={b.w} height={b.h} fill="#f1f5fb" stroke="#e2e8f0" stroke-width="1"/>
        ))}

        <!-- Suelo -->
        <line x1="0" y1="420" x2="1200" y2="420" stroke="#dde3ee" stroke-width="2"/>

        <!-- Capa delantera -->
        {buildings.map((b) => (
          <g class="bld" style={`--bd: ${b.d}`}>
            <rect x={b.x} y={b.y} width={b.w} height={b.h} fill="#ffffff" stroke="#d8dee9" stroke-width="1.5"/>
          </g>
        ))}

        <!-- Ventanas encendidas en la ciudad -->
        {cityWindows.map((w) => (
          <rect class="cwin" style={`--wd: ${w.d}`} x={w.x} y={w.y} width="10" height="14" rx="2" fill="#5266eb"/>
        ))}

        <!-- Edificio central: el centro de negocios -->
        <g class="bld" style="--bd: 0.28">
          <rect x="545" y="80" width="130" height="340" fill="#eef2ff" stroke="#5266eb" stroke-width="2"/>
          {windows.map((w) => (
            <rect class="win" style={`--wd: ${w.d}`} x={w.x} y={w.y} width="14" height="20" rx="2" fill="#5266eb"/>
          ))}

          <!-- Pancarta negra característica de Cirilo Amorós sobre la azotea -->
          <g class="casign">
            <rect x="545" y="46" width="130" height="28" fill="#111114"/>
            <text x="610" y="64.5" text-anchor="middle" font-size="13" font-weight="600" letter-spacing="0.5" fill="#ffffff">Cirilo Amorós</text>
          </g>
        </g>

        <!-- Metro (inicio de la ruta a pie) + ruta que se dibuja + punto que la recorre.
             En x≈400 para que quede dentro del recorte lateral del móvil. -->
        <g class="metro">
          <text x="400" y="362" text-anchor="middle" font-size="11" font-weight="500" fill="#6b7280">Metro Xàtiva</text>
          <!-- Vagón de metro -->
          <rect x="384" y="370" width="32" height="36" rx="9" fill="#ffffff" stroke="#5266eb" stroke-width="1.5"/>
          <rect x="390" y="376" width="20" height="12" rx="2.5" fill="#5266eb" opacity="0.85"/>
          <line x1="390" y1="394" x2="410" y2="394" stroke="#5266eb" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="392" cy="401" r="1.8" fill="#5266eb"/>
          <circle cx="408" cy="401" r="1.8" fill="#5266eb"/>
        </g>
        <path
          class="route"
          d="M 419 412 L 600 412"
          stroke="#5266eb" stroke-width="2" fill="none"
          stroke-dasharray="181 181" stroke-linecap="round"
        />
        <circle class="walker" cx="419" cy="412" r="4" fill="#5266eb"/>
        <text class="routelabel" x="510" y="400" text-anchor="middle" font-size="12" fill="#6b7280">3 min a pie</text>
      </svg>
    </div>

    <!-- Chips de beneficios flotantes -->
    {chips.map((c) => (
      <div
        class={`hero-chip absolute z-10 flex items-center gap-2 rounded-full border border-accent-100 bg-white/90
                px-3 py-1.5 text-[11px] font-medium text-gray-700 shadow-sm backdrop-blur-sm sm:px-3.5 sm:text-xs
                ${c.side === "left" ? "left-[4%] sm:left-[10%]" : "right-[3%] sm:right-[8%]"}`}
        style={`bottom: calc(var(--sceneH) * ${c.bottom}); --cd: ${c.d}`}
        aria-hidden="true"
      >
        <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500"></span>
        {c.text}
      </div>
    ))}

    <!-- Texto central -->
    <div
      class="hero-copy relative z-10 mx-auto flex h-full w-full max-w-3xl flex-col items-center justify-center px-6 text-center"
      style="padding-bottom: calc(var(--sceneH) * 0.7)"
    >
      <!-- Badge de ubicación -->
      <div
        class="hero-enter mb-7 inline-flex w-fit items-center gap-2 rounded-full border border-accent-200
               bg-accent-50 px-3.5 py-1.5 text-xs font-medium text-accent-700"
        style="animation-delay: 0ms"
      >
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-2.079 3.953-5.159 3.953-8.827a8.25 8.25 0 0 0-16.5 0c0 3.668 2.009 6.748 3.953 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd"/>
        </svg>
        Junto a Calle Colón · Valencia centro
      </div>

      <!-- Headline principal (H1) -->
      <h1
        class="hero-enter headline text-[2.5rem] leading-[1.1] text-gray-900 sm:text-5xl lg:text-[3.5rem] xl:text-[4rem]"
        style="animation-delay: 120ms"
      >
        Tu despacho<br />
        en el corazón<br />
        <span class="text-accent-600">de Valencia.</span>
      </h1>

      <!-- Subheadline -->
      <p
        class="hero-enter mt-5 max-w-lg text-base leading-relaxed text-gray-500 sm:text-lg"
        style="animation-delay: 260ms"
      >
        Despachos privados, salas de reuniones y domiciliación empresarial
        en el centro de negocios de referencia de Valencia.
        Todo incluido, sin inversión inicial.
      </p>

      <!-- CTAs -->
      <div class="hero-enter mt-8 flex flex-wrap justify-center gap-3" style="animation-delay: 380ms">
        <a href="/contacto?motivo=visita" class="btn-primary shadow-sm">
          Reservar visita
        </a>
        <a href="/tarifas" class="btn-secondary shadow-sm">
          Ver tarifas
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"></path>
          </svg>
        </a>
      </div>

      <!-- Valoración Google -->
      <div class="hero-enter mt-9 flex items-center gap-3" style="animation-delay: 500ms">
        <Stars rating={site.google.rating} class="h-4 w-4" />
        <p class="text-sm text-gray-500">
          <strong class="font-semibold text-gray-800">{rating}</strong>
          {" "}de valoración en Google
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Altura del recorrido del "vídeo". Valores por defecto de las variables:
     escena terminada (sin JS / reduced-motion el hero se ve completo). */
  #hero-scrub {
    height: 260vh;
    --pDraw: 1;
    --pLight: 1;
    --pZoom: 0;
    --pText: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    #hero-scrub { height: auto; }
  }

  /* Tamaño de la escena. En móvil la ciudad ocupa más (75vw de alto,
     recortando los laterales — el edificio central queda centrado);
     en pantallas mayores, proporción completa sin recortes. */
  .hero-sticky {
    --sceneH: min(70vw, 34svh);
  }
  @media (min-width: 640px) {
    .hero-sticky {
      --sceneH: min(35vw, 46svh);
    }
  }

  /* Escena — zoom sutil conforme avanza */
  .hero-scene {
    transform: scale(calc(1 + var(--pZoom) * 0.05));
    transform-origin: 50% 100%;
    will-change: transform;
  }

  /* Capa trasera — entra antes y se desplaza menos (profundidad) */
  .bldb {
    opacity: calc(var(--pDraw) * 0.9);
    transform: translateY(calc((1 - var(--pDraw)) * 36px));
    will-change: transform, opacity;
  }

  /* Capa delantera — edificios que se levantan (stagger por --bd) */
  .bld {
    --bt: clamp(0, calc((var(--pDraw) - var(--bd)) * 2.6), 1);
    transform: translateY(calc((1 - var(--bt)) * 130px));
    opacity: var(--bt);
    will-change: transform, opacity;
  }

  /* Ventanas del edificio central */
  .win {
    opacity: clamp(0, calc((var(--pLight) - var(--wd)) * 5), 1);
  }

  /* Ventanas de la ciudad (tenues) */
  .cwin {
    opacity: calc(clamp(0, calc((var(--pLight) - var(--wd)) * 6), 1) * 0.45);
  }

  /* Chip de dirección en la azotea — aparece con pop y halo suave */
  .casign {
    --ct: clamp(0, calc((var(--pLight) - 0.45) * 4), 1);
    opacity: var(--ct);
    transform: translateY(calc((1 - var(--ct)) * 8px));
    filter: drop-shadow(0 0 calc(var(--ct) * 8px) rgba(82, 102, 235, 0.35));
  }

  /* Pin "estás aquí", ruta y caminante */
  .metro {
    opacity: clamp(0, calc(var(--pLight) * 4), 1);
  }
  .route {
    stroke-dashoffset: calc(181 * (1 - var(--pLight)));
  }
  .walker {
    transform: translateX(calc(var(--pLight) * 181px));
    opacity: clamp(0, calc(var(--pLight) * 4), 1);
    will-change: transform;
  }
  .routelabel {
    opacity: clamp(0, calc((var(--pLight) - 0.5) * 4), 1);
  }

  /* Chips de beneficios — pop escalonado */
  .hero-chip {
    --ct: clamp(0, calc((var(--pLight) - var(--cd)) * 4), 1);
    opacity: var(--ct);
    transform: translateY(calc((1 - var(--ct)) * 14px)) scale(calc(0.95 + var(--ct) * 0.05));
    will-change: transform, opacity;
  }

  /* Cielo que vira al atardecer */
  .hero-skyshift {
    opacity: calc(var(--pLight) * 0.55);
    pointer-events: none;
  }

  /* Texto — se desvanece al final del recorrido */
  .hero-copy {
    opacity: calc(1 - var(--pText));
    transform: translateY(calc(var(--pText) * -36px));
  }

  /* Sol / halo que sube e intensifica tras el edificio */
  .hero-sun {
    position: absolute;
    left: 50%;
    bottom: calc(var(--sceneH) * 0.45);
    width: 380px;
    height: 380px;
    border-radius: 9999px;
    background: radial-gradient(circle, rgba(82, 102, 235, 0.30), transparent 68%);
    filter: blur(42px);
    opacity: calc(0.35 + var(--pLight) * 0.5);
    transform: translate(-50%, calc((1 - var(--pLight)) * 60px)) scale(calc(1 + var(--pLight) * 0.25));
    pointer-events: none;
    will-change: transform, opacity;
  }

  /* Aurora ambiental (independiente del scroll) */
  .hero-aurora {
    position: absolute;
    border-radius: 9999px;
    filter: blur(72px);
    opacity: 0.35;
    pointer-events: none;
    will-change: transform;
  }
  .hero-aurora--a {
    width: 34vw; height: 34vw; min-width: 300px; min-height: 300px;
    left: -5vw; top: -6vw;
    background: radial-gradient(circle, rgba(82, 102, 235, 0.50), transparent 70%);
    animation: heroAurora 17s ease-in-out infinite;
  }
  .hero-aurora--b {
    width: 30vw; height: 30vw; min-width: 280px; min-height: 280px;
    right: -4vw; top: 18%;
    background: radial-gradient(circle, rgba(120, 140, 255, 0.42), transparent 70%);
    animation: heroAurora 21s ease-in-out infinite reverse;
  }
  @keyframes heroAurora {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(38px, 26px) scale(1.12); }
  }

  /* Partículas ascendentes */
  .hero-particle {
    position: absolute;
    bottom: 8vh;
    border-radius: 9999px;
    background: rgba(82, 102, 235, 0.75);
    box-shadow: 0 0 8px rgba(82, 102, 235, 0.5);
    opacity: 0;
    animation: heroFloat 9s linear infinite;
    pointer-events: none;
  }
  @keyframes heroFloat {
    0%   { transform: translateY(0) scale(1);   opacity: 0; }
    12%  { opacity: 0.8; }
    88%  { opacity: 0.4; }
    100% { transform: translateY(-58vh) scale(0.5); opacity: 0; }
  }
</style>

<script>
  // Scrub del hero — progreso ligado al scroll (reversible, tipo vídeo).
  // Síncrono en el scroll (solo asigna variables CSS): no depende de
  // requestAnimationFrame, que el navegador pausa en segundo plano.
  const wrap = document.getElementById("hero-scrub");
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (wrap && !reduced) {
    const seg = (p: number, a: number, b: number) =>
      Math.min(Math.max((p - a) / (b - a), 0), 1);

    const apply = () => {
      const r = wrap.getBoundingClientRect();
      const total = r.height - window.innerHeight;
      const p = total > 0 ? Math.min(Math.max(-r.top / total, 0), 1) : 1;

      wrap.style.setProperty("--pDraw",  seg(p, 0.02, 0.40).toFixed(4));
      wrap.style.setProperty("--pLight", seg(p, 0.36, 0.78).toFixed(4));
      wrap.style.setProperty("--pZoom",  seg(p, 0.15, 1.00).toFixed(4));
      wrap.style.setProperty("--pText",  seg(p, 0.80, 0.985).toFixed(4));
    };

    document.addEventListener("scroll", apply, { passive: true });
    window.addEventListener("resize", apply, { passive: true });
    apply();
  }
</script>
