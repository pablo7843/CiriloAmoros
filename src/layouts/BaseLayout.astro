---
import "../styles/global.css";
import { site } from "../data/site";
import { services } from "../data/services";
import { reviews } from "../data/reviews";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BackgroundFX from "../components/BackgroundFX.astro";
import Intro from "../components/Intro.astro";
import ChatWidget from "../components/ChatWidget.svelte";

interface Props {
  title:       string;
  description?: string;
  ogImage?:    string;
  noindex?:    boolean;
  /** Muestra la portada de entrada a pantalla completa (solo home). */
  intro?:      boolean;
}

const {
  title,
  description = site.meta.description,
  ogImage     = site.meta.ogImage,
  noindex     = false,
  intro       = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle    = title.includes(site.shortName)
  ? title
  : `${title} ${site.meta.titleSuffix}`;

const hasBusinessUrl = !site.google.businessUrl.startsWith("[PENDIENTE");

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name":       site.name,
  "url":        Astro.site,
  "telephone":  site.contact.phone,
  "email":      site.contact.email,
  "priceRange": site.pricing.priceRange,
  "image":      new URL(site.meta.ogImage, Astro.site).href,
  "address": {
    "@type":           "PostalAddress",
    "streetAddress":   site.address.street,
    "addressLocality": site.address.city,
    "addressRegion":   site.address.region,
    "postalCode":      site.address.postalCode,
    "addressCountry":  site.address.country,
  },
  "geo": {
    "@type":     "GeoCoordinates",
    "latitude":  site.address.lat,
    "longitude": site.address.lng,
  },
  "areaServed": {
    "@type": "City",
    "name":  "Valencia",
  },
  "openingHoursSpecification": site.schedule.structured.map((s) => ({
    "@type":     "OpeningHoursSpecification",
    "dayOfWeek": s.days,
    "opens":     s.opens,
    "closes":    s.closes,
  })),
  ...(hasBusinessUrl ? { "sameAs": [site.google.businessUrl] } : {}),
  "makesOffer": services.map((svc) => ({
    "@type": "Offer",
    "name":  svc.name,
    "price": svc.priceFrom,
    "priceCurrency": svc.priceCurrency,
    "url":   new URL(svc.slug, Astro.site).href,
  })),
  "aggregateRating": {
    "@type":       "AggregateRating",
    "ratingValue": site.google.rating,
    "reviewCount": site.google.reviewCount,
    "bestRating":  5,
    "worstRating": 1,
  },
  "review": reviews.map((r) => ({
    "@type": "Review",
    "author":        { "@type": "Person", "name": r.author },
    "datePublished": r.date,
    "reviewBody":    r.text,
    "reviewRating":  {
      "@type":       "Rating",
      "ratingValue": r.rating,
      "bestRating":  5,
      "worstRating": 1,
    },
  })),
};
---

<!DOCTYPE html>
<html lang="es" class={intro ? "intro-pending" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={new URL(ogImage, Astro.site)} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content={site.meta.locale} />
    <meta property="og:site_name"   content={site.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={new URL(ogImage, Astro.site)} />

    <!-- Datos estructurados LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Inter — preconectar antes de pedir la fuente -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <div id="scroll-progress" aria-hidden="true"></div>
    <BackgroundFX />
    {intro && <Intro />}
    {intro && <div id="intro-spacer" aria-hidden="true" style="height: 100svh"></div>}
    <Header />
    <slot />
    <Footer />
    <ChatWidget client:idle />
  </body>

  <!-- Sin JS: todos los elementos visibles -->
  <noscript>
    <style>
      [data-reveal] { opacity: 1 !important; transform: none !important; }
      /* La portada necesita JS para deslizarse: sin JS, se oculta y se
         muestra la web directamente. */
      #intro, #intro-spacer { display: none !important; }
      html.intro-pending header { transform: none !important; }
    </style>
  </noscript>

  <script>
    // ── Scroll reveal ────────────────────────────────
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // ── Ancla entre páginas (p. ej. /#resenas desde otra página) ──
    // Llega a la home ARRIBA del todo y luego BAJA con animación hasta el
    // destino (no un salto). Cancelamos el salto nativo al ancla, mostramos
    // el inicio un instante y después hacemos scroll suave.
    if (location.hash.length > 1) {
      const targetId = location.hash.slice(1);
      try { history.scrollRestoration = "manual"; } catch {}
      window.scrollTo(0, 0);

      const animateToHash = () => {
        const el = document.getElementById(targetId);
        if (!el) return;
        if (prefersReduced) {
          el.scrollIntoView({ behavior: "auto", block: "start" });
        } else {
          window.scrollTo(0, 0);
          setTimeout(() => el.scrollIntoView({ behavior: "smooth", block: "start" }), 650);
        }
      };
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(animateToHash);
      else window.addEventListener("load", animateToHash);
    }

    // ── Portada de entrada — el "primer folio" se desliza al hacer scroll ──
    // Scroll nativo (móvil + PC) y totalmente reversible. Al llegar al final,
    // el header cae desde arriba (clase intro-pending en <html>).
    const intro       = document.getElementById("intro");
    const introSpacer = document.getElementById("intro-spacer");
    const docEl       = document.documentElement;
    if (intro && introSpacer) {
      if (prefersReduced) {
        // Sin movimiento: se aparta la portada y se muestra la web directamente.
        intro.style.display = "none";
        introSpacer.style.display = "none";
        docEl.classList.remove("intro-pending");
      } else {
        // La portada (logo) queda FIJA detrás (-z-[1]); la web sube con el
        // scroll nativo y la va cubriendo desde abajo. Trabajo síncrono para
        // no depender de requestAnimationFrame (se pausa en segundo plano).
        const apply = () => {
          const H = introSpacer.offsetHeight || window.innerHeight;
          const p = Math.min(Math.max(window.scrollY / H, 0), 1);

          // Una vez cubierta, se oculta para que las secciones translúcidas de
          // más abajo no la dejen entrever; al subir, reaparece.
          intro.style.visibility = p >= 0.999 ? "hidden" : "visible";

          // Al completar (web arriba del todo) baja el header; al subir, se esconde.
          if (p >= 0.95) docEl.classList.remove("intro-pending");
          else docEl.classList.add("intro-pending");
        };
        document.addEventListener("scroll", apply, { passive: true });
        window.addEventListener("resize", apply, { passive: true });
        apply();
      }
    }

    // ── Motor de scroll-scrub genérico ──
    // Pone --p (0→1) en cada [data-scrub] según la sección cruza el viewport.
    // Las escenas (líneas que se dibujan, contadores, barras…) leen --p en CSS.
    // Síncrono en el scroll; no depende de requestAnimationFrame.
    if (!prefersReduced) {
      const scrubEls = Array.from(
        document.querySelectorAll<HTMLElement>("[data-scrub]")
      );
      if (scrubEls.length) {
        const updateScrub = () => {
          const vh = window.innerHeight;
          for (const el of scrubEls) {
            const r = el.getBoundingClientRect();
            const span = parseFloat(el.dataset.scrubSpan || "0.55"); // fracción del viewport
            const start = vh * 0.88;          // empieza al entrar (top al 88%)
            const end   = vh * (0.88 - span); // termina al subir
            const p = Math.min(Math.max((start - r.top) / (start - end), 0), 1);
            el.style.setProperty("--p", p.toFixed(4));
          }
        };
        document.addEventListener("scroll", updateScrub, { passive: true });
        window.addEventListener("resize", updateScrub, { passive: true });
        updateScrub();
      }
    }

    // ── FAQ acordeón animado (altura + fade, grupo exclusivo) ──
    const faqItems = Array.from(
      document.querySelectorAll<HTMLDetailsElement>("details.faq-item")
    );
    const openFaq = (det: HTMLDetailsElement) => {
      const content = det.querySelector<HTMLElement>(".faq-content");
      det.open = true;
      if (prefersReduced || !content) return;
      const h = content.scrollHeight;
      content.animate(
        [{ height: "0px", opacity: 0 }, { height: h + "px", opacity: 1 }],
        { duration: 320, easing: "cubic-bezier(0.22, 1, 0.36, 1)" }
      );
    };
    const closeFaq = (det: HTMLDetailsElement) => {
      const content = det.querySelector<HTMLElement>(".faq-content");
      if (prefersReduced || !content) { det.open = false; return; }
      const h = content.scrollHeight;
      const anim = content.animate(
        [{ height: h + "px", opacity: 1 }, { height: "0px", opacity: 0 }],
        { duration: 260, easing: "cubic-bezier(0.22, 1, 0.36, 1)" }
      );
      anim.onfinish = () => { det.open = false; };
    };
    for (const det of faqItems) {
      const summary = det.querySelector("summary");
      summary?.addEventListener("click", (e) => {
        e.preventDefault();
        if (!det.open) {
          const name = det.getAttribute("name");
          if (name) {
            for (const other of faqItems) {
              if (other !== det && other.getAttribute("name") === name && other.open) {
                closeFaq(other);
              }
            }
          }
          openFaq(det);
        } else {
          closeFaq(det);
        }
      });
    }

    if (!prefersReduced) {
      document.documentElement.classList.add("js-reveal");

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -48px 0px" }
      );

      document.querySelectorAll("[data-reveal]").forEach((el) => {
        revealObserver.observe(el);
      });
    } else {
      document.querySelectorAll("[data-reveal]").forEach((el) => {
        el.classList.add("revealed");
      });
    }

    // ── Contador animado (Stats) ─────────────────────
    function easeOutQuart(t: number): number {
      return 1 - Math.pow(1 - t, 4);
    }

    function animateCount(
      el: Element,
      target: number,
      decimals: number,
      duration = 1800
    ) {
      const start = performance.now();
      const step = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const value = easeOutQuart(progress) * target;
        el.textContent = decimals > 0
          ? value.toFixed(decimals).replace(".", ",")
          : String(Math.round(value));
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }

    const statsSection = document.getElementById("stats-section");
    if (statsSection && !prefersReduced) {
      const statsObserver = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) {
            document
              .querySelectorAll<HTMLElement>("[data-count-to]")
              .forEach((el) => {
                const target   = parseFloat(el.dataset.countTo ?? "0");
                const decimals = parseInt(el.dataset.decimals ?? "0", 10);
                animateCount(el, target, decimals);
              });
            statsObserver.disconnect();
          }
        },
        { threshold: 0.4 }
      );
      statsObserver.observe(statsSection);
    }

    // ── Dinamismo (parallax, tilt, magnético, progreso) ──
    // Todo desactivado bajo prefers-reduced-motion. Los efectos
    // de puntero solo en ratón/trackpad (pointer: fine).
    if (!prefersReduced) {
      const finePointer = window.matchMedia("(pointer: fine)").matches;
      const EASE = "transform .5s cubic-bezier(0.22, 1, 0.36, 1)";

      // 1) Barra de progreso de scroll
      const bar = document.getElementById("scroll-progress");
      if (bar) {
        const onScroll = () => {
          const doc = document.documentElement;
          const max = doc.scrollHeight - doc.clientHeight;
          const p   = max > 0 ? doc.scrollTop / max : 0;
          bar.style.transform = `scaleX(${p})`;
        };
        document.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      // 2) Parallax de imágenes al hacer scroll
      const pImgs = Array.from(
        document.querySelectorAll<HTMLElement>("[data-parallax-img]")
      );
      if (pImgs.length) {
        let ticking = false;
        const update = () => {
          const vh = window.innerHeight;
          for (const el of pImgs) {
            const host = el.parentElement;
            if (!host) continue;
            const r    = host.getBoundingClientRect();
            const prog = (r.top + r.height / 2 - vh / 2) / vh; // -1..1 aprox
            el.style.transform = `translate3d(0, ${(prog * 26).toFixed(1)}px, 0) scale(1.14)`;
          }
          ticking = false;
        };
        document.addEventListener(
          "scroll",
          () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          },
          { passive: true }
        );
        window.addEventListener("resize", update, { passive: true });
        update();
      }

      if (finePointer) {
        // 3) Parallax de ratón en el hero (capas con data-depth)
        const hero = document.querySelector<HTMLElement>("[data-hero]");
        if (hero) {
          const layers = Array.from(
            hero.querySelectorAll<HTMLElement>("[data-depth]")
          );
          hero.addEventListener("pointermove", (e) => {
            const r = hero.getBoundingClientRect();
            const x = (e.clientX - r.left) / r.width - 0.5;
            const y = (e.clientY - r.top) / r.height - 0.5;
            for (const l of layers) {
              const d     = parseFloat(l.dataset.depth ?? "0");
              // Las imágenes a sangre llevan un leve zoom para que el
              // desplazamiento no descubra los bordes.
              const scale = l.tagName === "IMG" ? " scale(1.1)" : "";
              l.style.transition = "none";
              l.style.transform  =
                `translate3d(${(-x * d).toFixed(1)}px, ${(-y * d).toFixed(1)}px, 0)${scale}`;
            }
          });
          hero.addEventListener("pointerleave", () => {
            for (const l of layers) {
              l.style.transition = EASE;
              l.style.transform  = "";
            }
          });
        }

        // 4) Tilt 3D en tarjetas (data-tilt)
        const tilts = Array.from(
          document.querySelectorAll<HTMLElement>("[data-tilt]")
        );
        for (const card of tilts) {
          const MAX = 6; // grados
          card.addEventListener("pointermove", (e) => {
            const r  = card.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            card.style.transition = "none";
            card.style.transform  =
              `perspective(900px) rotateY(${(px * MAX).toFixed(2)}deg) rotateX(${(-py * MAX).toFixed(2)}deg)`;
          });
          card.addEventListener("pointerleave", () => {
            card.style.transition = EASE;
            card.style.transform  = "";
          });
        }

        // (Botones magnéticos eliminados — se deja solo el hover sutil por CSS)
      }
    }
  </script>

  <!-- GSAP — revelado de titulares línea a línea (SplitText + ScrollTrigger) -->
  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { SplitText } from "gsap/SplitText";

    const reducedGsap = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const splitTargets = document.querySelectorAll<HTMLElement>("[data-split]");

    if (!reducedGsap && splitTargets.length) {
      gsap.registerPlugin(ScrollTrigger, SplitText);
      // Oculta los titulares hasta que GSAP los prepara (evita parpadeo).
      document.documentElement.classList.add("gsap-split");

      const run = () => {
        try {
          splitTargets.forEach((el) => {
            const split = new SplitText(el, {
              type: "lines",
              mask: "lines",
              linesClass: "split-line",
            });
            gsap.set(el, { autoAlpha: 1 });
            gsap.from(split.lines, {
              yPercent: 115,
              opacity: 0,
              duration: 0.9,
              ease: "power3.out",
              stagger: 0.12,
              scrollTrigger: { trigger: el, start: "top 85%", once: true },
            });
          });
          ScrollTrigger.refresh();
        } catch (e) {
          // Si algo falla, nunca dejar los titulares ocultos.
          document.documentElement.classList.remove("gsap-split");
        }
      };

      // Espera a las fuentes para medir bien los saltos de línea.
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(run);
      } else {
        window.addEventListener("load", run);
      }
    }
  </script>
</html>
