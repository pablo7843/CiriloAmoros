---
import BaseLayout from "../layouts/BaseLayout.astro";
import Faq        from "../components/Faq.astro";
import CtaFinal   from "../components/CtaFinal.astro";
import { services } from "../data/services";
import { site } from "../data/site";

const service = services.find((s) => s.id === "salas")!;
const features = service.features.filter((f) => !f.startsWith("[PENDIENTE"));

const equipment = [
  { label: "Pantalla de gran formato",  desc: "Ideal para presentaciones" },
  { label: "Proyector",                  desc: "Alta resolución" },
  { label: "Videoconferencia",           desc: "Sistema integrado" },
  { label: "Internet de alta velocidad", desc: "WiFi + cable Ethernet" },
  { label: "Agua y café",               desc: "Para todos los asistentes" },
  { label: "Pizarra y material",        desc: "Rotuladores y soporte" },
];

const useCases = [
  "Entrevistas de trabajo",
  "Reuniones con clientes",
  "Presentaciones comerciales",
  "Juntas y consejos",
  "Formaciones y talleres",
  "Sesiones de trabajo en equipo",
];
---

<BaseLayout
  title="Salas de reuniones en Valencia centro · Desde 16 €/hora"
  description="Alquiler de salas de reuniones equipadas en Calle Cirilo Amorós 6, Valencia. Pantalla, proyector, videoconferencia e internet incluidos. Reserva por horas sin contrato."
>

  <!-- ── Hero ── -->
  <section class="border-b border-gray-100 bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-6">

      <nav aria-label="Ruta de navegación" class="mb-8">
        <ol class="flex items-center gap-2 text-xs text-gray-400">
          <li><a href="/" class="transition-colors hover:text-gray-600">Inicio</a></li>
          <li aria-hidden="true">›</li>
          <li class="font-medium text-gray-700" aria-current="page">Salas de reuniones</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-end">
        <div>
          <div class="hero-enter mb-5 inline-flex items-center gap-2 rounded-full border border-accent-200 bg-accent-50 px-3.5 py-1.5 text-xs font-semibold text-accent-700" style="animation-delay: 0ms">
            Salas de reuniones
          </div>
          <h1 class="hero-enter text-[2.5rem] font-bold leading-[1.1] tracking-tight text-gray-900 sm:text-5xl lg:text-[3.25rem]" style="animation-delay: 120ms">
            Reúnete con<br />
            <span class="text-accent-600">profesionalidad.</span>
          </h1>
          <p class="hero-enter mt-5 max-w-lg text-base leading-relaxed text-gray-500 sm:text-lg" style="animation-delay: 260ms">
            Salas completamente equipadas para reuniones, presentaciones y formaciones.
            Reserva por horas sin necesidad de contrato previo.
          </p>
        </div>

        <div class="hero-enter flex flex-col gap-6 lg:items-end" style="animation-delay: 200ms">
          <div class="flex items-baseline gap-1.5">
            <span class="text-5xl font-bold tracking-tight text-gray-900">{service.priceFrom} €</span>
            <span class="text-lg text-gray-500">/{service.priceUnit}</span>
            <span class="text-sm text-gray-400">· {service.priceNote}</span>
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              href="/contacto?servicio=salas&motivo=reserva"
              class="inline-flex items-center rounded-xl bg-accent-600 px-6 py-3.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2"
            >
              Reservar sala
            </a>
            <a
              href={site.contact.phoneHref}
              class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-6 py-3.5 text-sm font-semibold text-gray-700 shadow-sm transition-colors hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-200 focus:ring-offset-2"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
              </svg>
              {site.contact.phone}
            </a>
          </div>
          <p class="text-xs text-gray-400 lg:text-right">
            [PENDIENTE: capacidad máxima por sala a confirmar con el centro]
          </p>
        </div>
      </div>

      <!-- Imagen placeholder -->
      <div class="hero-enter mt-14 aspect-[21/9] overflow-hidden rounded-2xl bg-gray-100 relative" style="animation-delay: 380ms">
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-3" aria-hidden="true">
          <svg class="h-10 w-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
          </svg>
          <p class="text-xs text-gray-400">Foto de la sala de reuniones · [pendiente fotografía real]</p>
        </div>
        <img
          src="/images/sala-reuniones.jpg"
          alt="Sala de reuniones en Cirilo Amorós Centro Empresarial"
          class="absolute inset-0 h-full w-full object-cover"
          loading="eager"
          decoding="async"
          onerror="this.style.display='none'"
        />
      </div>
    </div>
  </section>

  <!-- ── Equipamiento ── -->
  <section aria-labelledby="equipamiento-titulo" class="bg-gray-50 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-6">

      <div class="mb-12 max-w-xl" data-reveal>
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Lo que encontrará</p>
        <h2 id="equipamiento-titulo" class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Equipada para cualquier reunión.
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {equipment.map((item, i) => (
          <div class="flex items-start gap-4 rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100" data-reveal style={`transition-delay: ${i * 80}ms`}>
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-50">
              <svg class="h-5 w-5 text-accent-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900">{item.label}</p>
              <p class="mt-0.5 text-xs text-gray-500">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Casos de uso ── -->
  <section aria-labelledby="usecases-titulo" class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-20" data-reveal>
        <div class="lg:w-72 shrink-0">
          <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">¿Para qué?</p>
          <h2 id="usecases-titulo" class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            Una sala para cada necesidad.
          </h2>
        </div>
        <div class="flex flex-wrap gap-2.5">
          {useCases.map((u) => (
            <span class="inline-flex items-center rounded-full border border-gray-200 bg-gray-50 px-4 py-2 text-sm font-medium text-gray-700">
              {u}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Precios ── -->
  <section aria-labelledby="precios-salas-titulo" class="bg-gray-50 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-6">

      <div class="mb-12" data-reveal>
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Tarifas</p>
        <h2 id="precios-salas-titulo" class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Reserva lo que necesitas.
        </h2>
      </div>

      <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200" data-reveal style="transition-delay: 120ms">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr class="bg-gray-50">
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Modalidad</th>
              <th scope="col" class="px-6 py-4 text-right text-xs font-bold uppercase tracking-wider text-gray-500">Precio</th>
              <th scope="col" class="hidden px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500 sm:table-cell">Ideal para</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr>
              <td class="px-6 py-4">
                <p class="text-sm font-semibold text-gray-900">Por hora</p>
              </td>
              <td class="px-6 py-4 text-right">
                <span class="text-lg font-bold text-gray-900">16 €</span>
                <span class="text-sm text-gray-400"> /h</span>
              </td>
              <td class="hidden px-6 py-4 text-sm text-gray-500 sm:table-cell">Reuniones cortas, entrevistas</td>
            </tr>
            <tr>
              <td class="px-6 py-4">
                <p class="text-sm font-semibold text-gray-900">Media jornada</p>
                <p class="text-xs text-gray-400">4 horas</p>
              </td>
              <td class="px-6 py-4 text-right">
                <span class="text-sm italic text-gray-400">[PENDIENTE]</span>
              </td>
              <td class="hidden px-6 py-4 text-sm text-gray-500 sm:table-cell">Formaciones, presentaciones</td>
            </tr>
            <tr>
              <td class="px-6 py-4">
                <p class="text-sm font-semibold text-gray-900">Jornada completa</p>
                <p class="text-xs text-gray-400">8 horas</p>
              </td>
              <td class="px-6 py-4 text-right">
                <span class="text-sm italic text-gray-400">[PENDIENTE]</span>
              </td>
              <td class="hidden px-6 py-4 text-sm text-gray-500 sm:table-cell">Jornadas intensivas, talleres</td>
            </tr>
          </tbody>
        </table>
        <div class="border-t border-gray-100 bg-gray-50 px-6 py-3">
          <p class="text-xs text-gray-400">Precios sin IVA (21%). [PENDIENTE: confirmar tarifas de media y jornada completa]</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <Faq category="salas" />

  <!-- ── CTA final ── -->
  <CtaFinal />

</BaseLayout>
