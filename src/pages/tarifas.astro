---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaFinal   from "../components/CtaFinal.astro";
import Faq        from "../components/Faq.astro";
import ShowcaseBand from "../components/ShowcaseBand.astro";
import FeatureIcon from "../components/FeatureIcon.astro";
import Aurora     from "../components/Aurora.astro";
import TariffCalculator from "../components/TariffCalculator.svelte";
import { services } from "../data/services";
import { site } from "../data/site";

// Tarjetas de precio: Despachos privados destacado y en el centro.
const priceCards = ["salas", "despachos", "oficina-virtual"]
  .map((id) => services.find((s) => s.id === id))
  .filter(Boolean) as typeof services;

// Mismos iconos que en la home (Services.astro) para mantener coherencia.
const icons = {
  despachos:        `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />`,
  salas:            `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />`,
  "oficina-virtual":`<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />`,
};

const rows = [
  { label: "Precio base",             despacho: `desde ${services[0].priceFrom} €/mes`, sala: `${services[1].priceFrom} €/hora`, virtual: `desde ${services[2].priceFrom} €/mes` },
  { label: "Nota de precio",          despacho: "Sin IVA", sala: "Sin IVA", virtual: "Sin IVA" },
  { label: "Acceso 24/7",             despacho: true,  sala: false, virtual: false },
  { label: "Llave / acceso propio",   despacho: true,  sala: false, virtual: false },
  { label: "Recepción de visitas",    despacho: true,  sala: true,  virtual: true  },
  { label: "Dirección comercial",     despacho: true,  sala: false, virtual: true  },
  { label: "Dirección fiscal",        despacho: true,  sala: false, virtual: true  },
  { label: "Recepción de correo",     despacho: true,  sala: false, virtual: true  },
  { label: "Internet incluido",       despacho: true,  sala: true,  virtual: false },
  { label: "Limpieza",                despacho: true,  sala: true,  virtual: false },
  { label: "Climatización",           despacho: true,  sala: true,  virtual: false },
  { label: "Uso de sala de reuniones",despacho: "Incluido puntual", sala: "Por horas", virtual: "Precio especial" },
  { label: "Permanencia mínima",      despacho: "1 mes", sala: "Sin contrato", virtual: "1 mes" },
];
---

<BaseLayout
  title="Tarifas de despachos y salas en Valencia"
  description="Precios sin sorpresas: despachos desde 320 €/mes, salas desde 16 €/h, oficina virtual desde 40 €/mes. Todo incluido, sin IVA. Valencia centro."
>

  <!-- ── Cabecera ── -->
  <section class="relative overflow-hidden border-b border-gray-100 bg-white py-16 sm:py-20">
    <Aurora tone="light" />
    <div class="relative z-10 mx-auto max-w-7xl px-6">

      <nav aria-label="Ruta de navegación" class="mb-8">
        <ol class="flex items-center gap-2 text-xs text-gray-400">
          <li><a href="/" class="transition-colors hover:text-gray-600">Inicio</a></li>
          <li aria-hidden="true">›</li>
          <li class="font-medium text-gray-700" aria-current="page">Tarifas</li>
        </ol>
      </nav>

      <div class="max-w-2xl">
        <p class="hero-enter mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600" style="animation-delay: 0ms">Tarifas</p>
        <h1 data-split class="headline text-[2.5rem] leading-[1.08] text-gray-900 sm:text-5xl">
          Precios transparentes.<br />Sin sorpresas.
        </h1>
        <p class="hero-enter mt-5 text-base leading-relaxed text-gray-500" style="animation-delay: 240ms">
          Todos los precios son sin IVA (21%). Una cuota fija que cubre todo lo que necesitas.
          Sin costes de comunidad, sin suministros aparte, sin mantenimiento.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Cards de precios destacados ── -->
  <section aria-label="Precios principales" class="bg-gray-50 py-14 sm:py-16">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">

        {priceCards.map((service, i) => (
          <article data-reveal data-tilt style={`transition-delay: ${i * 100}ms`}
            class={[
              "group relative flex flex-col overflow-hidden rounded-2xl border shadow-md transition-shadow duration-300 hover:shadow-2xl",
              i === 1
                ? "border-accent-300 bg-accent-50 ring-1 ring-accent-200 lg:scale-[1.04]"
                : "border-gray-200 bg-white",
            ].join(" ")}
          >
            <div class="px-7 pt-8 pb-6">
              <div class={[
                "mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl",
                i === 1 ? "bg-accent-100 text-accent-600" : "bg-gray-100 text-gray-600",
              ].join(" ")}>
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" set:html={icons[service.id as keyof typeof icons]} />
              </div>
              <h3 class="text-lg font-medium text-gray-900">{service.name}</h3>
              <p class="mt-1 text-sm text-gray-500">{service.headline}</p>
              <div class="mt-4 flex items-baseline gap-1">
                <span class="text-3xl font-bold tracking-tight text-gray-900">{service.priceFrom} €</span>
                <span class="text-sm text-gray-500">/{service.priceUnit}</span>
                <span class="ml-2 text-xs text-gray-400">{service.priceNote}</span>
              </div>
            </div>

            <div class="flex-1 border-t border-gray-100 px-7 py-6">
              <ul class="space-y-2.5">
                {service.features.filter((f) => !f.startsWith("[PENDIENTE")).slice(0, 5).map((feature) => (
                  <li class="flex items-start gap-2.5 text-sm text-gray-600">
                    <FeatureIcon label={feature} class="mt-0.5 h-4 w-4 shrink-0 text-accent-500" />
                    {feature}
                  </li>
                ))}
              </ul>
            </div>

            <div class="px-7 pb-7">
              <a
                href={service.slug}
                class={[
                  "flex w-full items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-medium transition-colors",
                  "focus:outline-none focus:ring-2 focus:ring-offset-2",
                  i === 1
                    ? "bg-accent-600 text-white hover:bg-accent-700 focus:ring-accent-500"
                    : "border border-gray-200 bg-white text-gray-700 hover:border-gray-300 hover:bg-gray-50 focus:ring-gray-300",
                ].join(" ")}
              >
                Ver detalles
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Calculadora de tarifas ── -->
  <section aria-labelledby="calc-titulo" class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-5xl px-6">
      <div class="mb-10" data-reveal>
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Calculadora</p>
        <h2 id="calc-titulo" class="headline text-3xl text-gray-900 sm:text-4xl">
          Calcula tu tarifa al instante.
        </h2>
        <p class="mt-3 text-base leading-relaxed text-gray-500">
          Ajusta las opciones y te mostramos una estimación. Sin compromiso.
        </p>
      </div>
      <div data-reveal style="transition-delay: 120ms">
        <TariffCalculator client:visible />
      </div>
    </div>
  </section>

  <!-- ── Tabla comparativa ── -->
  <section aria-labelledby="tabla-titulo" class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">

      <div class="mb-12" data-reveal>
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Comparativa</p>
        <h2 id="tabla-titulo" class="headline text-3xl text-gray-900 sm:text-4xl">
          ¿Cuál es tu plan ideal?
        </h2>
      </div>

      <!-- Tabla comparativa (escritorio) -->
      <div class="hidden overflow-x-auto sm:block" data-reveal style="transition-delay: 120ms">
        <table class="min-w-full">
          <thead>
            <tr class="border-b border-gray-200">
              <th scope="col" class="py-5 pl-5 pr-6 text-left text-sm font-medium text-gray-500 w-[40%]">
                Característica
              </th>
              {services.map((s, i) => (
                <th
                  scope="col"
                  class={`px-6 py-5 text-center text-sm font-bold ${i === 0 ? "text-gray-900" : "text-gray-700"}`}
                >
                  {s.name}
                  <span class={`block text-xs font-normal mt-0.5 ${i === 0 ? "text-accent-600" : "text-gray-400"}`}>
                    desde {s.priceFrom} €/{s.priceUnit}
                  </span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.slice(2).map((row) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-5 pl-5 pr-6 text-sm text-gray-700">{row.label}</td>
                {[row.despacho, row.sala, row.virtual].map((val) => (
                  <td class="px-6 py-5 text-center text-sm">
                    {val === true ? (
                      <span class="inline-flex justify-center">
                        <svg class="h-5 w-5 text-accent-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-label="Incluido">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
                        </svg>
                      </span>
                    ) : val === false ? (
                      <span class="inline-flex justify-center">
                        <svg class="h-5 w-5 text-gray-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-label="No incluido">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
                        </svg>
                      </span>
                    ) : (val as string).startsWith("[PENDIENTE") ? (
                      <span class="text-xs italic text-gray-300">Consultar</span>
                    ) : (
                      <span class="text-gray-600">{val}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Comparativa apilada por plan (móvil) -->
      <div class="space-y-5 sm:hidden">
        {services.map((s, idx) => {
          const key = (["despacho", "sala", "virtual"] as const)[idx];
          const featured = idx === 0;
          return (
            <div data-reveal class={["rounded-2xl border p-6", featured ? "border-accent-300 bg-accent-50/50 ring-1 ring-accent-200" : "border-gray-200 bg-white"].join(" ")}>
              <div class="mb-4 flex items-baseline justify-between gap-3 border-b border-gray-100 pb-3">
                <h3 class="text-base font-bold text-gray-900">{s.name}</h3>
                <span class="shrink-0 text-sm font-semibold text-accent-600">desde {s.priceFrom} €/{s.priceUnit}</span>
              </div>
              <ul class="space-y-2.5">
                {rows.slice(2).map((row) => {
                  const val = row[key];
                  return (
                    <li class="flex items-start justify-between gap-4 text-sm">
                      <span class="text-gray-600">{row.label}</span>
                      {val === true ? (
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-accent-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-label="Incluido"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                      ) : val === false ? (
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-gray-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-label="No incluido"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                      ) : (val as string).startsWith("[PENDIENTE") ? (
                        <span class="shrink-0 text-xs italic text-gray-400">Consultar</span>
                      ) : (
                        <span class="shrink-0 text-right font-medium text-gray-900">{val}</span>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          );
        })}
      </div>

      <!-- Notas -->
      <div class="mt-8 space-y-2 border-t border-gray-100 pt-6">
        <p class="text-xs text-gray-400">
          * Todos los precios son sin IVA. El IVA aplicable es el 21%.
        </p>
        <p class="text-xs text-gray-400">
          * Los precios son orientativos y pueden variar según el espacio elegido. Contáctanos para un presupuesto personalizado.
        </p>
        <p class="text-xs text-gray-400">
          * Permanencia mínima de un mes; después, renovación flexible mes a mes.
        </p>
      </div>
    </div>
  </section>

  <!-- ── ¿Tiene dudas? ── -->
  <section class="bg-gray-50 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-6 text-center" data-reveal>
      <h2 class="headline text-2xl text-gray-900 sm:text-3xl">¿No sabes cuál es tu plan ideal?</h2>
      <p class="mt-3 text-base text-gray-500">
        Cuéntanos tu situación y te asesoramos sin compromiso. Hay un plan para cada caso.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/contacto"
          class="btn-primary shadow-sm"
        >
          Solicitar asesoramiento
        </a>
        <a
          href={site.contact.phoneHref}
          class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 transition-colors hover:text-gray-900"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
          </svg>
          {site.contact.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ── FAQ de precios ── -->
  <ShowcaseBand
    image="/images/despacho-principal.webp"
    eyebrow="Sin sorpresas"
    title="Todo incluido en una sola cuota."
    text="Sin costes de comunidad, sin suministros aparte, sin mantenimiento. Una tarifa clara y un espacio listo para trabajar."
    chips={["Sin inversión inicial", "Sin permanencia larga", "Acceso 24/7"]}
  />

  <Faq category="precios" />

  <!-- ── CTA final ── -->
  <CtaFinal
    eyebrow="Tu plan ideal"
    headline="El plan perfecto para ti,<br />sin compromiso."
    image="/images/despacho-principal.webp"
  />

</BaseLayout>
