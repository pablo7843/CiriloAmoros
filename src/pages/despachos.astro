---
import BaseLayout from "../layouts/BaseLayout.astro";
import Faq        from "../components/Faq.astro";
import CtaFinal   from "../components/CtaFinal.astro";
import { services } from "../data/services";
import { site } from "../data/site";

const service = services.find((s) => s.id === "despachos")!;
const features = service.features.filter((f) => !f.startsWith("[PENDIENTE"));

const profiles = [
  "Abogados y asesores",
  "Médicos y psicólogos",
  "Consultores de negocio",
  "Arquitectos y diseñadores",
  "Agentes comerciales",
  "Coaches y formadores",
  "Startups y emprendedores",
  "Profesionales independientes",
];

const included = [
  { label: "Acceso 24/7 con llave propia",    icon: "key"   },
  { label: "Recepción y atención de visitas", icon: "user"  },
  { label: "Internet de alta velocidad",      icon: "wifi"  },
  { label: "Limpieza incluida",               icon: "star"  },
  { label: "Climatización",                   icon: "temp"  },
  { label: "Dirección comercial y postal",    icon: "mail"  },
  { label: "Sala de reuniones (uso puntual)", icon: "group" },
  { label: "Zona común y cocina",             icon: "home"  },
];
---

<BaseLayout
  title="Despachos privados en Valencia centro · Desde 320 €/mes"
  description="Alquiler de despachos privados totalmente equipados en Calle Cirilo Amorós 6, Valencia. Acceso 24/7, recepción, internet y domiciliación incluidos. Sin inversión inicial."
>

  <!-- ── Hero de página ── -->
  <section class="relative flex flex-col overflow-hidden lg:flex-row lg:min-h-[calc(100svh-4rem)]">

    <!-- Imagen -->
    <div class="relative order-first h-64 overflow-hidden sm:h-80 lg:order-last lg:h-auto lg:flex-1">
      <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-br from-gray-100 via-gray-200 to-gray-300 text-center" aria-hidden="true">
        <svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
        </svg>
        <p class="text-xs text-gray-400">Foto despacho<br/><span class="text-gray-300">[pendiente]</span></p>
      </div>
      <img
        src="/images/despacho-principal.jpg"
        alt="Despacho privado en alquiler en Valencia centro — Cirilo Amorós Centro Empresarial"
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
        onerror="this.style.display='none'"
      />
      <div class="absolute inset-y-0 left-0 hidden w-24 bg-gradient-to-r from-white to-transparent lg:block" aria-hidden="true"></div>
    </div>

    <!-- Texto -->
    <div class="flex flex-col justify-center px-6 py-14 lg:order-first lg:w-[58%] lg:py-24 lg:pl-16 lg:pr-8 xl:pl-24">

      <nav aria-label="Ruta de navegación" class="mb-8">
        <ol class="flex items-center gap-2 text-xs text-gray-400">
          <li><a href="/" class="transition-colors hover:text-gray-600">Inicio</a></li>
          <li aria-hidden="true">›</li>
          <li class="font-medium text-gray-700" aria-current="page">Despachos privados</li>
        </ol>
      </nav>

      <div class="hero-enter mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-accent-200 bg-accent-50 px-3.5 py-1.5 text-xs font-semibold text-accent-700" style="animation-delay: 0ms">
        Despachos privados
      </div>

      <h1 class="hero-enter text-[2.5rem] font-bold leading-[1.1] tracking-tight text-gray-900 sm:text-5xl lg:text-[3.25rem]" style="animation-delay: 120ms">
        Su despacho.<br />
        <span class="text-accent-600">Listo desde el primer día.</span>
      </h1>

      <p class="hero-enter mt-5 max-w-lg text-base leading-relaxed text-gray-500 sm:text-lg" style="animation-delay: 260ms">
        Despachos privados totalmente equipados en una de las mejores direcciones de Valencia.
        Entra y trabaja desde el primer día. Sin inversión inicial.
      </p>

      <div class="hero-enter mt-7 flex items-baseline gap-1.5" style="animation-delay: 380ms">
        <span class="text-4xl font-bold tracking-tight text-gray-900">{service.priceFrom} €</span>
        <span class="text-base text-gray-500">/{service.priceUnit}</span>
        <span class="text-sm text-gray-400">· {service.priceNote}</span>
      </div>

      <div class="hero-enter mt-7 flex flex-wrap gap-3" style="animation-delay: 460ms">
        <a
          href="/contacto?servicio=despachos&motivo=visita"
          class="inline-flex items-center rounded-xl bg-accent-600 px-6 py-3.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2"
        >
          Solicitar visita
        </a>
        <a
          href="/tarifas"
          class="inline-flex items-center gap-1.5 rounded-xl border border-gray-200 bg-white px-6 py-3.5 text-sm font-semibold text-gray-700 shadow-sm transition-colors hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-200 focus:ring-offset-2"
        >
          Ver todos los precios
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Qué incluye ── -->
  <section aria-labelledby="incluye-titulo" class="bg-gray-50 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-6">

      <div class="mb-12 max-w-xl" data-reveal>
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">Todo incluido</p>
        <h2 id="incluye-titulo" class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Sin sorpresas al final de mes.
        </h2>
        <p class="mt-3 text-base leading-relaxed text-gray-500">
          Una cuota mensual fija que cubre todo lo que necesita para trabajar.
          Sin letras pequeñas, sin extras inesperados.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {features.map((feat, i) => (
          <div class="flex items-start gap-3 rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100" data-reveal style={`transition-delay: ${i * 80}ms`}>
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-accent-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
            </svg>
            <span class="text-sm font-medium text-gray-800">{feat}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ¿Para quién es? ── -->
  <section aria-labelledby="perfiles-titulo" class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-20">

        <div class="lg:w-80 shrink-0" data-reveal>
          <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.2em] text-accent-600">¿Para quién?</p>
          <h2 id="perfiles-titulo" class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            Ideal para profesionales que valoran la imagen.
          </h2>
        </div>

        <div class="flex flex-wrap gap-2.5" data-reveal style="transition-delay: 120ms">
          {profiles.map((p) => (
            <span class="inline-flex items-center rounded-full border border-gray-200 bg-gray-50 px-4 py-2 text-sm font-medium text-gray-700">
              {p}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <Faq category="despachos" />

  <!-- ── CTA final ── -->
  <CtaFinal />

</BaseLayout>
